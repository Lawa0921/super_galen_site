# 環境變數範例檔案
# 複製為 .env 並填入真實值

# Polygon 私鑰 (用於部署到 Polygon 主網/測試網)
PRIVATE_KEY=your_private_key_here

# Polygon API 金鑰 (用於合約驗證)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# RPC URLs (可選，使用預設值或自定義)
POLYGON_RPC_URL=https://polygon-rpc.com/
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# ── 線上對戰（Dungeon Arcade）牽線 / 排行榜用的 Upstash Redis ──
# production 必填（多實例需共享 store）；本機開發留空會自動退回記憶體 mock。
# 取得方式：Vercel → Storage → 建立 Upstash（KV）免費 DB，會自動注入這兩個變數；
#           或 Upstash console 建免費 DB 後複製 REST URL / TOKEN 貼到 Vercel 環境變數。
# 帳單安全：用免費方案、不要綁信用卡 → 超量只會被擋、不會扣款。
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# 重要提醒：
# 1. 絕對不要將真實的私鑰提交到版本控制
# 2. 確保 .env 檔案已加入 .gitignore
# 3. 測試環境可使用 Hardhat 預設帳戶
# 4. 生產環境務必使用硬體錢包或多重簽名錢包