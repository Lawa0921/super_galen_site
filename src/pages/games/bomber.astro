  }
  .ms-solo:hover {
    border-color: rgba(255, 157, 60, 1);
  }

  /* ─── Central divider / emblem ───────────────────────── */
  .divider-seam {
    position: absolute;
    /* Sits at the join of the two cards, centered horizontally */
    left: 50%;
    top: 0;
    bottom: 0;
    transform: translateX(-50%);
    /* Bold metallic seam strip */
    width: 14px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-evenly;
    /* Metallic amber strip gradient */
    background: linear-gradient(
      to right,
      rgba(255, 90, 20, 0.12) 0%,
      rgba(255, 157, 60, 0.55) 40%,
      rgba(255, 220, 100, 0.75) 50%,
      rgba(255, 157, 60, 0.55) 60%,
      rgba(255, 90, 20, 0.12) 100%
    );
    box-shadow:
      0 0 18px rgba(255, 157, 60, 0.6),
      0 0 40px rgba(255, 90, 77, 0.3);
    pointer-events: none;
  }

  /* Decorative rivets */
  .rivet {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      #fff2e6 0%,
      #ffb84d 40%,
      #cc6600 100%
    );
    box-shadow:
      0 0 6px rgba(255, 157, 60, 0.9),
      0 0 12px rgba(255, 90, 0, 0.5);
