---
/**
 * /games/bomber — Dungeon Arcade: Dungeon Bomber
 * Layout B: Cinematic hero-stage select (4 characters, roster panel)
 * 模式：SOLO；全螢幕 PixiJS 遊戲頁，由頁底腳本載入並 code-split。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import { defaultLang, type Language } from '@i18n/index';
import { CHARACTERS } from '@scripts/games/bomber/engine/characters';

const lang: Language = defaultLang;

const chars = [CHARACTERS.lena, CHARACTERS.mira, CHARACTERS.aya, CHARACTERS.rosa];

const roleLabels: Record<string, string> = {
  lena: '工兵 / 坦',
  mira: '魔女 / 爆發',
  aya:  '斥候 / 高速',
  rosa: '隊長 / 重裝',
};

// Per-stat caps for bar scaling
const barMax = { lives: 5, maxBombs: 8, fireRange: 8, speedLevel: 4 };

type StatKey = keyof typeof barMax;

const statRows: { key: StatKey; label: string; icon: string }[] = [
  { key: 'lives',      label: '命',   icon: 'ic-life' },
  { key: 'maxBombs',   label: '炸彈', icon: 'ic-bomb' },
  { key: 'fireRange',  label: '火力', icon: 'ic-fire' },
  { key: 'speedLevel', label: '速度', icon: 'ic-speed' },
];

// Per-character cinematic metadata
const heroMeta: Record<string, { rom: string; epithet: string; aura: string; elem: string }> = {
  lena: { rom: 'LENA', epithet: 'THE DEMOLITION ACE', aura: '#ff9d3c', elem: 'ic-bomb' },
  mira: { rom: 'MIRA', epithet: 'THE BOMB-WITCH',     aura: '#ff5a4d', elem: 'ic-fire' },
  aya:  { rom: 'AYA',  epithet: 'THE SWIFT SHADOW',   aura: '#36e0c0', elem: 'ic-speed' },
  rosa: { rom: 'ROSA', epithet: 'THE IRON CAPTAIN',   aura: '#6b9fd0', elem: 'ic-life' },
};
---

<BaseLayout
  title="Dungeon Arcade — Dungeon Bomber"
  description="像素地城炸彈生存"
  lang={lang}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
  />

  <main class="bomber-page">
    <a class="bomber-back" href="/games">← ARCADE</a>
    <p class="bomber-hint">MOVE WASD/←→↑↓ · BOMB SPACE · MUTE M</p>
    <div class="bomber-stage">
      <canvas id="bomber-canvas"></canvas>
    </div>

    <!-- ── Mode Select — Layout B: Cinematic Hero Stage ── -->
    <div class="mode-select" id="mode-select">
      <!-- CRT scanline + vignette overlay -->
      <div class="crt-overlay" aria-hidden="true"></div>

      <!-- Decorative hanging chains (top corners) -->
      <div class="chain chain--left" aria-hidden="true"></div>
      <div class="chain chain--right" aria-hidden="true"></div>

      <!-- Outer arcade bezel frame corners -->
      <div class="bezel-corner bezel-corner--tl" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--tr" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--bl" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--br" aria-hidden="true"></div>

      <!-- Title bar (full width, top) -->
      <div class="ms-header">
        <h2 class="ms-title">SELECT YOUR BOMBER</h2>
      </div>

      <!-- ── Main Stage Area ── -->
      <div class="stage-area">

        <!-- Hero panels (one per character, only active one is visible) -->
        <div class="hero-stage">
          {chars.map((profile, idx) => {
            const id = profile.id;
            const meta = heroMeta[id];
            return (
              <div
                class={`hero-panel${idx === 0 ? ' is-active' : ''}`}
                data-char-panel={id}
                style={`--aura:${meta.aura}; background:url('/assets/games/bomber/ui/hero-${id}.png') center/cover no-repeat; image-rendering:pixelated;`}
              >
                <!-- Huge glowing name block (upper-left) -->
                <div class="hero-name-block">
                  <div class="hero-rom">{meta.rom}</div>
                  <div class="hero-name-cn">{profile.name}</div>
                  <div class="hero-epithet">{meta.epithet}</div>
                </div>

                <!-- Compact stats chip (bottom-left) -->
                <div class="hero-stats-chip">
                  {statRows.map(({ key, label, icon }) => {
                    const startVal = profile.start[key];
                    const capVal   = profile.caps[key];
                    return (
                      <div class="chip-row">
                        <img
                          class="chip-icon"
                          src={`/assets/games/bomber/ui/${icon}.png`}
                          alt={label}
                          title={label}
                          width="12"
                          height="12"
                          style="image-rendering:pixelated"
                        />
                        <span class="chip-val">
                          <span class="chip-num">{startVal}</span>
                          <span class="chip-arrow">→</span>
                          <span class="chip-num chip-num--cap">{capVal}</span>
                        </span>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>

        <!-- Roster panel (right column) — tall framed face-portrait boxes -->
        <div class="roster">
          <div class="roster-label" aria-hidden="true">ROSTER</div>
          {chars.map((profile, idx) => {
            const id = profile.id;
            const meta = heroMeta[id];
            return (
              <button
                class={`roster-item${idx === 0 ? ' is-selected' : ''}`}
                data-char={id}
                type="button"
              >
                <!-- ► cursor arrow for selected state -->
                <span class="roster-cursor" aria-hidden="true">▶</span>
                <!-- Face portrait box -->
                <div class="roster-face-frame">
                  <img
                    src={`/assets/games/bomber/portraits/${id}-face.png`}
                    alt={profile.name}
                    class="roster-face"
                    width="52"
                    height="52"
                    style="image-rendering:pixelated"
                  />
                </div>
                <div class="roster-info">
                  <span class="roster-name">{profile.name}</span>
                  <span class="roster-meta">{meta.rom}</span>
                </div>
                <img
                  src={`/assets/games/bomber/ui/${meta.elem}.png`}
                  alt=""
                  class="roster-elem-icon"
                  width="20"
                  height="20"
                  style="image-rendering:pixelated"
                />
              </button>
            );
          })}

          <!-- START button in roster panel -->
          <button class="ms-btn ms-solo roster-start" data-action="start" type="button">
            ▶ START
          </button>
        </div>

      </div><!-- /stage-area -->

      <!-- Bottom PRESS START prompt (also clickable) -->
      <button class="press-start-prompt" data-action="start" type="button">
        ▶ PRESS 'START' TO SELECT
      </button>

    </div><!-- /mode-select -->

    <div class="bomber-over" id="bomber-over" hidden>
      <h2 class="ms-title">GAME OVER</h2>
      <p id="bomber-over-stats" class="over-stats"></p>
      <button class="ms-btn ms-solo" id="bomber-restart">RETRY</button>
    </div>
  </main>
</BaseLayout>

<style>
  /* ─── Page shell ─────────────────────────────────────── */
  .bomber-page {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background: #0a0c14;
    overflow: hidden;
  }
  .bomber-stage {
    position: absolute;
    inset: 0;
  }
  #bomber-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .bomber-back {
    position: absolute;
    top: 18px;
    left: 20px;
    z-index: 55;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: #c98f6a;
    text-decoration: none;
    opacity: 0.8;
  }
  .bomber-back:hover {
    opacity: 1;
    color: #ff9d3c;
  }
  .bomber-hint {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    z-index: 30;
    margin: 0;
    text-align: center;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: #c98f6a;
    opacity: 0.75;
    pointer-events: none;
    display: none; /* 僅遊戲中顯示；選角畫面隱藏（避免和 PRESS START 重疊），start() 時揭露 */
  }

  /* ─── Mode-select full-screen (Layout B) ─────────────── */
  .mode-select {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    font-family: 'Press Start 2P', Consolas, monospace;
    background: #0a0c14;
    overflow: hidden;
  }
  .mode-select[hidden] {
    display: none;
  }

  /* ─── CRT overlay (scanlines + vignette + flicker) ───── */
  .crt-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    background:
      repeating-linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0) 0px,
        rgba(0, 0, 0, 0) 2px,
        rgba(0, 0, 0, 0.13) 2px,
        rgba(0, 0, 0, 0.13) 3px
      ),
      radial-gradient(
        ellipse 92% 82% at 50% 50%,
        rgba(0, 0, 0, 0) 25%,
        rgba(4, 5, 14, 0.18) 65%,
        rgba(4, 5, 14, 0.42) 100%
      );
    animation: crt-flicker 5s steps(1) infinite;
  }
  @keyframes crt-flicker {
    0%,  94%, 96%, 100% { opacity: 1; }
    95% { opacity: 0.91; }
  }

  /* ─── Hanging chains (top corners) ──────────────────── */
  .chain {
    position: absolute;
    top: 0;
    width: 14px;
    height: clamp(60px, 12vh, 110px);
    pointer-events: none;
    z-index: 48;
    background: repeating-linear-gradient(
      to bottom,
      #2a1f0e 0px,
      #2a1f0e 5px,
      transparent 5px,
      transparent 7px,
      #3a2a10 7px,
      #3a2a10 12px,
      transparent 12px,
      transparent 14px
    );
    opacity: 0.85;
  }
  .chain::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 100%;
    background: repeating-linear-gradient(
      to bottom,
      rgba(255, 157, 60, 0.12) 0px,
      rgba(255, 157, 60, 0.12) 1px,
      transparent 1px,
      transparent 14px
    );
  }
  .chain--left  { left: clamp(18px, 3vw, 40px); }
  .chain--right { right: clamp(18px, 3vw, 40px); }

  /* ─── Bezel corner accents ───────────────────────────── */
  .bezel-corner {
    position: absolute;
    z-index: 48;
    width: 28px;
    height: 28px;
    pointer-events: none;
    border-color: #ff9d3c;
    border-style: solid;
    opacity: 0.75;
  }
  .bezel-corner--tl { top: 6px; left: 6px;   border-width: 3px 0 0 3px; }
  .bezel-corner--tr { top: 6px; right: 6px;  border-width: 3px 3px 0 0; }
  .bezel-corner--bl { bottom: 6px; left: 6px;  border-width: 0 0 3px 3px; }
  .bezel-corner--br { bottom: 6px; right: 6px; border-width: 0 3px 3px 0; }

  /* ─── Header / Title bar ─────────────────────────────── */
  .ms-header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding-top: clamp(8px, 1.4vh, 16px);
    padding-bottom: clamp(4px, 0.6vh, 10px);
    border-bottom: 2px solid rgba(255, 157, 60, 0.45);
    width: 100%;
    background: linear-gradient(
      to bottom,
      rgba(4, 5, 14, 0.88) 0%,
      rgba(4, 5, 14, 0.2) 100%
    );
    box-shadow: 0 3px 18px rgba(255, 157, 60, 0.18);
    flex-shrink: 0;
  }
  .ms-title {
    margin: 0;
    font-size: clamp(12px, 2.2vw, 24px);
    letter-spacing: clamp(3px, 0.7vw, 7px);
    color: #fff2e6;
    text-shadow:
      3px 3px 0 #0a0c14,
      -1px -1px 0 #0a0c14,
      0 0 10px rgba(255, 157, 60, 0.9),
      0 0 28px rgba(255, 157, 60, 0.6),
      0 0 55px rgba(255, 90, 77, 0.35);
  }

  /* ─── Stage area: hero stage (left) + roster (right) ─── */
  .stage-area {
    display: flex;
    flex-direction: row;
    flex: 1 1 auto;
    min-height: 0;
    position: relative;
    z-index: 5;
    background: rgba(4, 5, 14, 0.18);
  }

  /* ─── Hero stage panel (left/center, ~73% width) ─────── */
  .hero-stage {
    flex: 1 1 auto;
    min-width: 0;
    position: relative;
    overflow: hidden;
  }

  /* Hero panels: only .is-active is visible */
  .hero-panel {
    display: none;
    position: absolute;
    inset: 0;
    align-items: flex-start;
    justify-content: flex-end;
    box-sizing: border-box;
  }
  .hero-panel.is-active {
    display: block;
  }

  /* ─── HUGE glowing name block (upper-left of hero area) ─ */
  .hero-name-block {
    position: absolute;
    top: clamp(14px, 3vh, 38px);
    left: clamp(16px, 2.5vw, 36px);
    z-index: 5;
    pointer-events: none;
  }
  /* Big romanized name — THE HERO */
  .hero-rom {
    display: block;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: clamp(48px, 8vw, 112px);
    line-height: 1;
    letter-spacing: -1px;
    color: #ffce6b;
    text-shadow:
      4px 4px 0 #0a0c14,
      0 0 12px #ff9d3c,
      0 0 30px #ff6a2c,
      0 0 60px var(--aura);
    animation: name-glow-pulse 2.8s ease-in-out infinite;
  }
  @keyframes name-glow-pulse {
    0%, 100% {
      text-shadow:
        4px 4px 0 #0a0c14,
        0 0 12px #ff9d3c,
        0 0 30px #ff6a2c,
        0 0 60px var(--aura);
    }
    50% {
      text-shadow:
        4px 4px 0 #0a0c14,
        0 0 18px #ff9d3c,
        0 0 42px #ff6a2c,
        0 0 88px var(--aura);
    }
  }
  /* Chinese name — smaller, beside/under */
  .hero-name-cn {
    display: block;
    margin-top: clamp(2px, 0.5vh, 6px);
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: clamp(11px, 1.6vw, 20px);
    letter-spacing: 4px;
    color: #ffd7a8;
    text-shadow:
      2px 2px 0 #0a0c14,
      0 0 8px rgba(255, 157, 60, 0.7),
      0 0 20px rgba(255, 157, 60, 0.35);
  }
  /* Epithet subtitle */
  .hero-epithet {
    display: block;
    margin-top: clamp(4px, 0.8vh, 10px);
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: clamp(7px, 0.95vw, 10px);
    letter-spacing: clamp(2px, 0.4vw, 5px);
    color: #ff9d3c;
    text-shadow:
      1px 1px 0 #0a0c14,
      0 0 6px rgba(255, 157, 60, 0.55);
  }

  /* ─── Compact stats chip (bottom-left corner) ────────── */
  .hero-stats-chip {
    position: absolute;
    bottom: clamp(10px, 2vh, 24px);
    left: clamp(12px, 2vw, 28px);
    z-index: 5;
    display: flex;
    flex-direction: column;
    gap: 3px;
    background: rgba(6, 4, 16, 0.78);
    border: 1px solid rgba(255, 157, 60, 0.4);
    padding: clamp(4px, 0.6vh, 8px) clamp(6px, 0.8vw, 10px);
    box-shadow: 0 0 8px rgba(255, 90, 77, 0.1);
  }
  .chip-row {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .chip-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.8));
  }
  .chip-val {
    font-size: clamp(6px, 0.7vw, 8px);
    letter-spacing: 0;
    color: #ffd7a8;
  }
  .chip-num      { color: #ffd23f; }
  .chip-num--cap { color: #ff9d3c; }
  .chip-arrow    { color: #c98f6a; margin: 0 1px; }

  /* ─── Roster panel (right column, ~27% width) ────────── */
  .roster {
    flex: 0 0 clamp(150px, 24vw, 280px);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(4px, 0.7vh, 9px);
    padding: clamp(10px, 1.6vh, 20px) clamp(10px, 1.4vw, 18px);
    box-sizing: border-box;
    /* Metallic/stone panel with amber border */
    background: linear-gradient(
      180deg,
      rgba(6, 4, 18, 0.92) 0%,
      rgba(8, 6, 22, 0.88) 100%
    );
    border-left: 3px solid #ff9d3c;
    box-shadow:
      inset 3px 0 24px rgba(0, 0, 0, 0.45),
      -2px 0 16px rgba(255, 157, 60, 0.12);
    overflow-y: auto;
  }

  .roster-label {
    font-size: clamp(7px, 0.85vw, 8px);
    letter-spacing: 4px;
    color: rgba(255, 157, 60, 0.7);
    text-align: center;
    padding-bottom: clamp(5px, 0.8vh, 9px);
    border-bottom: 2px solid rgba(255, 157, 60, 0.35);
    margin-bottom: clamp(2px, 0.4vh, 6px);
    flex-shrink: 0;
    text-shadow: 0 0 6px rgba(255, 157, 60, 0.4);
  }

  /* ─── Individual roster item (face box) ──────────────── */
  .roster-item {
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: clamp(6px, 0.9vw, 10px);
    padding: clamp(5px, 0.8vh, 9px) clamp(6px, 0.9vw, 10px);
    padding-left: clamp(16px, 2.2vw, 22px); /* room for cursor */
    background: rgba(8, 6, 20, 0.72);
    border: 2px solid rgba(255, 157, 60, 0.28);
    box-sizing: border-box;
    cursor: pointer;
    text-align: left;
    font-family: 'Press Start 2P', Consolas, monospace;
    transition:
      border-color 0.13s ease,
      background 0.13s ease,
      transform 0.13s ease,
      box-shadow 0.13s ease;
    overflow: hidden;
    flex-shrink: 0;
  }
  .roster-item:hover {
    border-color: rgba(255, 157, 60, 0.65);
    background: rgba(255, 100, 30, 0.07);
    transform: translateX(-2px);
    box-shadow: 2px 0 12px rgba(255, 157, 60, 0.22);
  }
  .roster-item:focus-visible {
    outline: none;
    border-color: #ffd23f;
    box-shadow: 0 0 0 2px rgba(255, 210, 63, 0.4);
  }
  .roster-item.is-selected {
    border-color: #ff9d3c;
    background: rgba(255, 100, 20, 0.16);
    transform: translateX(-3px) scale(1.02);
    box-shadow:
      3px 0 22px rgba(255, 157, 60, 0.6),
      inset 0 0 16px rgba(255, 90, 30, 0.1);
  }

  /* ► cursor arrow — only visible when selected */
  .roster-cursor {
    position: absolute;
    left: 4px;
    top: 50%;
    transform: translateY(-50%);
    font-size: clamp(7px, 0.9vw, 9px);
    color: #ffd23f;
    opacity: 0;
    text-shadow: 0 0 6px rgba(255, 210, 63, 0.9);
    animation: cursor-blink 0.7s steps(1) infinite;
    pointer-events: none;
  }
  .roster-item.is-selected .roster-cursor {
    opacity: 1;
  }
  @keyframes cursor-blink {
    0%, 59% { opacity: 1; }
    60%, 100% { opacity: 0; }
  }

  /* Face portrait framed box */
  .roster-face-frame {
    width: clamp(40px, 6vw, 56px);
    height: clamp(40px, 6vw, 56px);
    flex-shrink: 0;
    border: 2px solid rgba(255, 157, 60, 0.45);
    overflow: hidden;
    background: rgba(4, 3, 12, 0.7);
    box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.6);
    transition: border-color 0.13s ease, box-shadow 0.13s ease;
  }
  .roster-item.is-selected .roster-face-frame {
    border-color: #ffd23f;
    box-shadow:
      0 0 10px rgba(255, 210, 63, 0.55),
      inset 0 0 6px rgba(0, 0, 0, 0.5);
  }
  .roster-face {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.13s ease;
    filter: brightness(0.85);
  }
  .roster-item.is-selected .roster-face {
    filter: brightness(1.05) drop-shadow(0 0 4px rgba(255, 157, 60, 0.5));
  }

  /* Roster name + rom text */
  .roster-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    flex: 1;
  }
  .roster-name {
    font-size: clamp(8px, 1vw, 11px);
    letter-spacing: 1px;
    color: #fff2e6;
    text-shadow: 1px 1px 0 #0a0c14;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .roster-item.is-selected .roster-name {
    color: #ffd23f;
    text-shadow: 1px 1px 0 #0a0c14, 0 0 6px rgba(255, 210, 63, 0.65);
  }
  .roster-meta {
    font-size: clamp(5px, 0.6vw, 7px);
    letter-spacing: 1.5px;
    color: #c98f6a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Element icon (right side of roster item) */
  .roster-elem-icon {
    width: clamp(16px, 2.2vw, 22px);
    height: clamp(16px, 2.2vw, 22px);
    flex-shrink: 0;
    opacity: 0.75;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.7));
    transition: opacity 0.13s ease;
  }
  .roster-item.is-selected .roster-elem-icon {
    opacity: 1;
    filter:
      drop-shadow(0 1px 3px rgba(0, 0, 0, 0.8))
      drop-shadow(0 0 5px rgba(255, 157, 60, 0.55));
  }

  /* START button (in roster panel) */
  .ms-btn {
    padding: clamp(9px, 1.4vh, 14px) clamp(10px, 1.3vw, 18px);
    font-family: inherit;
    font-size: clamp(8px, 1vw, 11px);
    letter-spacing: 2px;
    color: #ffe9d6;
    background: rgba(8, 12, 22, 0.88);
    border: 3px solid rgba(255, 157, 60, 0.8);
    border-radius: 0;
    clip-path: polygon(
      0 6px, 6px 0,
      calc(100% - 6px) 0, 100% 6px,
      100% calc(100% - 6px), calc(100% - 6px) 100%,
      6px 100%, 0 calc(100% - 6px)
    );
    box-shadow:
      0 0 14px rgba(255, 157, 60, 0.42),
      inset 0 0 10px rgba(255, 90, 77, 0.07);
    cursor: pointer;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
    position: relative;
    z-index: 5;
    width: 100%;
    text-shadow: 1px 1px 0 #0a0c14, 0 0 6px rgba(255, 157, 60, 0.55);
  }
  .ms-btn:hover {
    transform: translateY(-3px) scale(1.04);
    color: #fff2e6;
    background: rgba(255, 90, 40, 0.18);
    box-shadow:
      0 0 28px rgba(255, 157, 60, 0.82),
      0 0 56px rgba(255, 90, 77, 0.45),
      inset 0 0 12px rgba(255, 157, 60, 0.13);
    text-shadow: 1px 1px 0 #0a0c14, 0 0 10px rgba(255, 200, 60, 1);
    border-color: #ff9d3c;
  }
  .ms-solo { border-color: rgba(255, 157, 60, 0.8); }
  .ms-solo:hover { border-color: rgba(255, 157, 60, 1); }

  .roster-start {
    margin-top: auto;
    flex-shrink: 0;
  }

  /* ─── Bottom PRESS START prompt ─────────────────────── */
  .press-start-prompt {
    position: relative;
    z-index: 10;
    flex-shrink: 0;
    display: block;
    width: 100%;
    padding: clamp(7px, 1.2vh, 12px) 0;
    background: rgba(4, 5, 14, 0.82);
    border: none;
    border-top: 2px solid rgba(255, 157, 60, 0.35);
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: clamp(8px, 1.1vw, 11px);
    letter-spacing: clamp(2px, 0.4vw, 5px);
    color: #ffd23f;
    text-align: center;
    cursor: pointer;
    text-shadow:
      1px 1px 0 #0a0c14,
      0 0 8px rgba(255, 210, 63, 0.7),
      0 0 20px rgba(255, 157, 60, 0.45);
    animation: blink-press 1s steps(1) infinite;
    box-shadow: 0 -4px 18px rgba(255, 157, 60, 0.14);
    transition: background 0.15s ease;
  }
  .press-start-prompt:hover {
    background: rgba(255, 90, 40, 0.1);
    animation-play-state: paused;
    opacity: 1;
  }
  @keyframes blink-press {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0.2; }
  }

  /* ─── Game Over overlay ──────────────────────────────── */
  .bomber-over {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    background: rgba(4, 6, 13, 0.84);
    font-family: 'Press Start 2P', Consolas, monospace;
  }
  .bomber-over[hidden] {
    display: none;
  }
  .over-stats {
    margin: 0;
    font-size: 13px;
    letter-spacing: 2px;
    color: #ffd23f;
    text-align: center;
    line-height: 1.8;
  }
</style>

<script>
  import { startBomber } from '@scripts/games/bomber/render/main';
  import type { CharacterId } from '@scripts/games/bomber/engine/types';

  const VALID_CHARS: CharacterId[] = ['lena', 'mira', 'aya', 'rosa'];

  const params = new URLSearchParams(location.search);
  const canvas = document.getElementById('bomber-canvas') as HTMLCanvasElement | null;
  const modeSelect = document.getElementById('mode-select');
  let started = false;

  // ── Selection state ──────────────────────────────────────
  let selected: CharacterId = 'lena';

  function setSelected(id: CharacterId): void {
    selected = id;

    // Toggle hero panels
    document.querySelectorAll<HTMLElement>('[data-char-panel]').forEach((panel) => {
      panel.classList.toggle('is-active', panel.dataset.charPanel === id);
    });

    // Toggle roster items
    document.querySelectorAll<HTMLElement>('[data-char]').forEach((item) => {
      if (item.tagName === 'BUTTON') {
        item.classList.toggle('is-selected', item.dataset.char === id);
      }
    });
  }

  // ── Start game ───────────────────────────────────────────
  function start(id: CharacterId): void {
    if (started || !canvas) return;
    started = true;
    modeSelect?.remove();
    const hint = document.querySelector('.bomber-hint') as HTMLElement | null;
    if (hint) hint.style.display = 'block';
    startBomber(canvas, id).catch((err: unknown) => console.error('[bomber] start failed', err));
  }

  // ── Roster item clicks ───────────────────────────────────
  modeSelect?.querySelectorAll<HTMLButtonElement>('.roster-item').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.char as CharacterId | undefined;
      if (id && (VALID_CHARS as string[]).includes(id)) setSelected(id);
    });
  });

  // ── START button click (roster panel + bottom prompt) ────
  modeSelect?.querySelectorAll<HTMLButtonElement>('[data-action="start"]').forEach((btn) => {
    btn.addEventListener('click', () => {
      start(selected);
    });
  });

  // ── Keyboard navigation ──────────────────────────────────
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (started) return;
    const idx = VALID_CHARS.indexOf(selected);
    if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
      e.preventDefault();
      setSelected(VALID_CHARS[(idx + 1) % VALID_CHARS.length]);
    } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
      e.preventDefault();
      setSelected(VALID_CHARS[(idx + VALID_CHARS.length - 1) % VALID_CHARS.length]);
    } else if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      start(selected);
    }
  });

  // ── Initialize selection UI ──────────────────────────────
  setSelected(selected);

  // ── Autostart: ?char= one of the 4 ──────────────────────
  const charParam = params.get('char') as CharacterId | null;
  if (charParam && (VALID_CHARS as string[]).includes(charParam)) {
    start(charParam);
  }

  // ── Autostart: ?mode=solo → lena (backward compat for e2e) ──
  if (!started && params.get('mode') === 'solo') {
    start('lena');
  }
</script>
