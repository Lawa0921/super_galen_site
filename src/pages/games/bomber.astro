---
/**
 * /games/bomber — Dungeon Arcade: Dungeon Bomber
 * 模式：SOLO；全螢幕 PixiJS 遊戲頁，由頁底腳本載入並 code-split。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import { defaultLang, type Language } from '@i18n/index';
import { CHARACTERS } from '@scripts/games/bomber/engine/characters';

const lang: Language = defaultLang;

const chars = [CHARACTERS.lena, CHARACTERS.mira];

// Role labels for each character (hardcoded, two-only)
const roleLabels: Record<string, string> = {
  lena: '工兵 / 坦',
  mira: '魔女 / 爆發',
};

// Per-stat caps for bar scaling
const barMax = { lives: 5, maxBombs: 8, fireRange: 8, speedLevel: 4 };

type StatKey = keyof typeof barMax;

const statRows: { key: StatKey; label: string; icon: string }[] = [
  { key: 'lives',      label: '命',   icon: 'ic-life' },
  { key: 'maxBombs',   label: '炸彈', icon: 'ic-bomb' },
  { key: 'fireRange',  label: '火力', icon: 'ic-fire' },
  { key: 'speedLevel', label: '速度', icon: 'ic-speed' },
];
---

<BaseLayout
  title="Dungeon Arcade — Dungeon Bomber"
  description="像素地城炸彈生存"
  lang={lang}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
  />

  <main class="bomber-page">
    <a class="bomber-back" href="/games">← ARCADE</a>
    <p class="bomber-hint">MOVE WASD/←→↑↓ · BOMB SPACE · MUTE M</p>
    <div class="bomber-stage">
      <canvas id="bomber-canvas"></canvas>
    </div>

    <div class="mode-select" id="mode-select">
      <!-- CRT scanline + vignette overlay -->
      <div class="crt-overlay" aria-hidden="true"></div>

      <!-- Title block -->
      <div class="ms-header">
        <h2 class="ms-title">SELECT YOUR BOMBER</h2>
        <p class="ms-subtitle">▶ PRESS START</p>
      </div>

      <!-- Two character stations filling the screen -->
      <div class="char-cards">
        {chars.map((profile, idx) => {
          const id = profile.id;
          const role = roleLabels[id] ?? '';
          return (
            <div class={`char-card char-card--${id}`} data-idx={idx}>

              <!-- Spotlight beam behind character (CSS-only per-card) -->
              <div class="spotlight-cone" aria-hidden="true"></div>

              <!-- Full-body standee zone -->
              <div class="char-figure">
                <img
                  src={`/assets/games/bomber/portraits/${id}-full.png`}
                  alt={profile.name}
                  class="char-fig-img"
                  style="image-rendering:pixelated"
                />
                <!-- Glow pool at feet -->
                <div class="ground-glow" aria-hidden="true"></div>
              </div>

              <!-- Name banner with notched corners -->
              <div class="char-banner">
                <div class="char-name">{profile.name}</div>
                <div class="char-role">{role}</div>
              </div>

              <!-- Segmented arcade stat gauges -->
              <div class="char-stats">
                {statRows.map(({ key, label, icon }) => {
                  const startVal = profile.start[key];
                  const capVal   = profile.caps[key];
                  const max      = barMax[key];
                  const pips = Array.from({ length: max }, (_, i) => {
                    if (i < startVal) return 'solid';
                    if (i < capVal)   return 'growth';
                    return 'empty';
                  });
                  return (
                    <div class="stat-row">
                      <img
                        class="stat-icon"
                        src={`/assets/games/bomber/ui/${icon}.png`}
                        alt={label}
                        title={label}
                        width="20"
                        height="20"
                        style="image-rendering:pixelated"
                      />
                      <div class="stat-pips">
                        {pips.map((kind) => (
                          <span class={`pip pip--${kind}`}></span>
                        ))}
                      </div>
                      <span class="stat-val">
                        <span class="stat-num">{startVal}</span>
                        <span class="arrow">→</span>
                        <span class="stat-num stat-num--cap">{capVal}</span>
                      </span>
                    </div>
                  );
                })}
              </div>

              <!-- START button -->
              <button class="ms-btn ms-solo char-start" data-char={id}>▶ START</button>
            </div>
          );
        })}
      </div>
    </div>

    <div class="bomber-over" id="bomber-over" hidden>
      <h2 class="ms-title">GAME OVER</h2>
      <p id="bomber-over-stats" class="over-stats"></p>
      <button class="ms-btn ms-solo" id="bomber-restart">RETRY</button>
    </div>
  </main>
</BaseLayout>

<style>
  /* ─── Page shell ─────────────────────────────────────── */
  .bomber-page {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background: #06070f;
    overflow: hidden;
  }
  .bomber-stage {
    position: absolute;
    inset: 0;
  }
  #bomber-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .bomber-back {
    position: absolute;
    top: 18px;
    left: 20px;
    z-index: 30;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: #c98f6a;
    text-decoration: none;
    opacity: 0.8;
  }
  .bomber-back:hover {
    opacity: 1;
    color: #ff9d3c;
  }
  .bomber-hint {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    z-index: 30;
    margin: 0;
    text-align: center;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: #c98f6a;
    opacity: 0.75;
    pointer-events: none;
  }

  /* ─── Mode-select full-screen ────────────────────────── */
  .mode-select {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    font-family: 'Press Start 2P', Consolas, monospace;
    /* Dramatic pixel arena background */
    background:
      url('/assets/games/bomber/ui/select-bg2.png') center / cover no-repeat;
    image-rendering: pixelated;
    overflow: hidden;
  }
  .mode-select[hidden] {
    display: none;
  }

  /* ─── CRT overlay (scanlines + vignette + flicker) ───── */
  .crt-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    /* Scanlines: 2px line every 3px */
    background:
      repeating-linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0) 0px,
        rgba(0, 0, 0, 0) 2px,
        rgba(0, 0, 0, 0.22) 2px,
        rgba(0, 0, 0, 0.22) 3px
      ),
      /* Vignette: dark at edges, open at center so spotlights shine */
      radial-gradient(
        ellipse 90% 80% at 50% 50%,
        rgba(0, 0, 0, 0) 30%,
        rgba(4, 5, 14, 0.55) 70%,
        rgba(4, 5, 14, 0.82) 100%
      );
    animation: crt-flicker 5s steps(1) infinite;
  }
  @keyframes crt-flicker {
    0%,  94%, 96%, 100% { opacity: 1; }
    95% { opacity: 0.92; }
  }

  /* ─── Header / Title ─────────────────────────────────── */
  .ms-header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding-top: clamp(10px, 1.8vh, 22px);
    padding-bottom: clamp(4px, 0.8vh, 12px);
    /* Thin amber top bar accent */
    border-bottom: 2px solid rgba(255, 157, 60, 0.4);
    width: 100%;
    background: linear-gradient(
      to bottom,
      rgba(4, 5, 14, 0.72) 0%,
      rgba(4, 5, 14, 0.28) 100%
    );
  }
  .ms-title {
    margin: 0;
    font-size: clamp(16px, 3.2vw, 34px);
    letter-spacing: clamp(3px, 0.8vw, 8px);
    color: #fff2e6;
    /* Chunky arcade: amber glow + black offset drop-shadow */
    text-shadow:
      4px 4px 0 #0a0c14,
      -2px -2px 0 #0a0c14,
      0 0 10px rgba(255, 157, 60, 1),
      0 0 28px rgba(255, 157, 60, 0.7),
      0 0 60px rgba(255, 90, 77, 0.4);
  }
  .ms-subtitle {
    margin: clamp(4px, 0.6vh, 8px) 0 0;
    font-size: clamp(7px, 1.1vw, 9px);
    letter-spacing: 2px;
    color: #ff9d3c;
    animation: blink-press 1s steps(1) infinite;
  }
  @keyframes blink-press {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* ─── Character cards row ───────────────────────────── */
  .char-cards {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    justify-content: stretch;
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
    position: relative;
    z-index: 5;
  }

  .char-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1 1 0;
    min-width: 0;
    overflow: hidden;
    padding: clamp(8px, 1.5vh, 18px) clamp(10px, 1.5vw, 28px) clamp(10px, 1.8vh, 20px);
    box-sizing: border-box;
    /* Dark semi-transparent station panel with amber double border */
    background: linear-gradient(
      to bottom,
      rgba(10, 8, 18, 0.55) 0%,
      rgba(8, 6, 14, 0.75) 100%
    );
    border: 3px solid rgba(255, 157, 60, 0.55);
    /* Pulsing neon amber frame at idle */
    box-shadow:
      inset 0 0 0 2px rgba(255, 90, 77, 0.15),
      0 0 18px rgba(255, 157, 60, 0.2),
      0 0 40px rgba(255, 90, 77, 0.1);
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease;
    animation: frame-pulse 2.4s ease-in-out infinite;
  }
  /* Slight stagger for right card */
  .char-card:last-child {
    animation-delay: 1.2s;
  }
  @keyframes frame-pulse {
    0%, 100% {
      box-shadow:
        inset 0 0 0 2px rgba(255, 90, 77, 0.15),
        0 0 18px rgba(255, 157, 60, 0.2),
        0 0 40px rgba(255, 90, 77, 0.1);
    }
    50% {
      box-shadow:
        inset 0 0 0 2px rgba(255, 90, 77, 0.30),
        0 0 32px rgba(255, 157, 60, 0.42),
        0 0 70px rgba(255, 90, 77, 0.22);
    }
  }
  /* A vertical divider line between cards */
  .char-card + .char-card {
    border-left: none;
  }
  .char-card + .char-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8%;
    bottom: 8%;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(255, 157, 60, 0.5) 30%,
      rgba(255, 157, 60, 0.5) 70%,
      transparent
    );
  }

  /* Hover / focus: brighter border, scale, fast neon pulse */
  .char-card:hover,
  .char-card:focus-within {
    border-color: rgba(255, 157, 60, 1);
    transform: scale(1.03);
    animation: frame-pulse-hot 0.6s ease-in-out infinite;
    z-index: 6;
  }
  @keyframes frame-pulse-hot {
    0%, 100% {
      box-shadow:
        inset 0 0 0 3px rgba(255, 90, 77, 0.5),
        0 0 28px rgba(255, 157, 60, 0.7),
        0 0 70px rgba(255, 90, 77, 0.45),
        0 0 120px rgba(255, 210, 63, 0.2);
    }
    50% {
      box-shadow:
        inset 0 0 0 3px rgba(255, 90, 77, 0.8),
        0 0 50px rgba(255, 157, 60, 1),
        0 0 100px rgba(255, 90, 77, 0.65),
        0 0 160px rgba(255, 210, 63, 0.35);
    }
  }
  /* Brighten spotlight on hover */
  .char-card:hover .spotlight-cone,
  .char-card:focus-within .spotlight-cone {
    opacity: 1;
  }
  /* Intensify ground glow on hover */
  .char-card:hover .ground-glow,
  .char-card:focus-within .ground-glow {
    opacity: 1;
    animation: ground-glow-pulse-hot 0.5s ease-in-out infinite;
  }

  /* ─── Spotlight cone (per-card CSS beam) ─────────────── */
  .spotlight-cone {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 70%;
    height: 65%;
    /* Warm conic beam from top center, fading to transparent */
    background: conic-gradient(
      from -12deg at 50% 0%,
      transparent 0deg,
      rgba(255, 200, 120, 0.07) 8deg,
      rgba(255, 175, 80, 0.14) 16deg,
      rgba(255, 155, 60, 0.12) 24deg,
      transparent 36deg
    );
    pointer-events: none;
    opacity: 0.7;
    transition: opacity 0.25s ease;
  }

  /* ─── Character figure zone ──────────────────────────── */
  .char-figure {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .char-fig-img {
    display: block;
    height: clamp(180px, 40vh, 440px);
    width: auto;
    object-fit: contain;
    /* Subtle warmth drop-shadow */
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.75))
            drop-shadow(0 0 6px rgba(255, 157, 60, 0.25));
    position: relative;
    z-index: 2;
    /* Idle bob animation */
    animation: idle-bob 2.2s ease-in-out infinite;
  }
  /* Second card (mira) offset so they're not in sync */
  .char-card:last-child .char-fig-img {
    animation-delay: -0.9s;
  }
  @keyframes idle-bob {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-6px); }
  }

  /* Ground glow ellipse at character's feet */
  .ground-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 28px;
    background: radial-gradient(
      ellipse at 50% 100%,
      rgba(255, 157, 60, 0.5) 0%,
      rgba(255, 90, 77, 0.2) 50%,
      transparent 100%
    );
    border-radius: 50%;
    pointer-events: none;
    opacity: 0.65;
    animation: ground-glow-pulse 2.2s ease-in-out infinite;
  }
  .char-card:last-child .ground-glow {
    animation-delay: -0.9s;
  }
  @keyframes ground-glow-pulse {
    0%, 100% { opacity: 0.55; transform: translateX(-50%) scaleX(1); }
    50%       { opacity: 0.85; transform: translateX(-50%) scaleX(1.12); }
  }
  @keyframes ground-glow-pulse-hot {
    0%, 100% { opacity: 0.9; transform: translateX(-50%) scaleX(1.1); }
    50%       { opacity: 1;   transform: translateX(-50%) scaleX(1.25); }
  }

  /* ─── Name banner (notched arcade plate) ─────────────── */
  .char-banner {
    width: 100%;
    text-align: center;
    padding: clamp(5px, 0.9vh, 10px) clamp(8px, 1vw, 14px);
    margin: clamp(4px, 0.6vh, 8px) 0;
    background: rgba(8, 6, 18, 0.78);
    border-top: 2px solid rgba(255, 157, 60, 0.7);
    border-bottom: 2px solid rgba(255, 157, 60, 0.7);
    /* Notched corners via clip-path */
    clip-path: polygon(
      0 8px, 8px 0,
      calc(100% - 8px) 0, 100% 8px,
      100% calc(100% - 8px), calc(100% - 8px) 100%,
      8px 100%, 0 calc(100% - 8px)
    );
    position: relative;
    z-index: 3;
  }
  .char-name {
    font-size: clamp(15px, 2vw, 24px);
    letter-spacing: 3px;
    color: #fff2e6;
    text-shadow:
      2px 2px 0 #0a0c14,
      0 0 8px rgba(255, 157, 60, 0.8),
      0 0 20px rgba(255, 157, 60, 0.4);
  }
  .char-role {
    margin-top: 3px;
    font-size: clamp(7px, 1vw, 9px);
    letter-spacing: 1.5px;
    color: #c98f6a;
  }

  /* ─── Segmented arcade stat gauges ───────────────────── */
  .char-stats {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: clamp(4px, 0.7vh, 8px);
    position: relative;
    z-index: 3;
  }
  .stat-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .stat-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.8));
  }
  .stat-pips {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 3px;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  .pip {
    display: inline-block;
    width: clamp(8px, 1.4vw, 16px);
    height: clamp(8px, 1.3vh, 14px);
    border-radius: 2px;
    flex-shrink: 0;
  }
  /* Solid filled pip: bright glowing amber */
  .pip--solid {
    background: linear-gradient(180deg, #ffda6b 0%, #ff8c1a 100%);
    box-shadow:
      0 0 4px rgba(255, 157, 60, 0.9),
      0 0 8px rgba(255, 157, 60, 0.5),
      inset 0 1px 0 rgba(255, 255, 180, 0.4);
    border: 1px solid rgba(255, 200, 60, 0.6);
  }
  /* Growth pip: dimmer outlined amber (cap potential) */
  .pip--growth {
    background: rgba(255, 130, 40, 0.18);
    border: 1px solid rgba(255, 157, 60, 0.45);
    box-shadow: 0 0 3px rgba(255, 157, 60, 0.2);
  }
  /* Empty pip: dark outline */
  .pip--empty {
    background: rgba(10, 12, 20, 0.6);
    border: 1px solid rgba(80, 60, 40, 0.4);
  }
  .stat-val {
    flex-shrink: 0;
    font-size: clamp(7px, 0.9vw, 9px);
    letter-spacing: 0;
    color: #ffd7a8;
    text-align: right;
    min-width: 36px;
  }
  .stat-num {
    color: #ffd23f;
  }
  .stat-num--cap {
    color: #ff9d3c;
  }
  .arrow {
    color: #c98f6a;
    margin: 0 1px;
  }

  /* ─── START button ───────────────────────────────────── */
  .ms-btn {
    padding: clamp(10px, 1.5vh, 16px) clamp(12px, 1.5vw, 22px);
    font-family: inherit;
    font-size: clamp(9px, 1.1vw, 12px);
    letter-spacing: 2px;
    color: #ffe9d6;
    background: rgba(8, 12, 22, 0.85);
    border: 3px solid rgba(255, 157, 60, 0.8);
    border-radius: 0;
    /* Notched plate look */
    clip-path: polygon(
      0 6px, 6px 0,
      calc(100% - 6px) 0, 100% 6px,
      100% calc(100% - 6px), calc(100% - 6px) 100%,
      6px 100%, 0 calc(100% - 6px)
    );
    box-shadow:
      0 0 14px rgba(255, 157, 60, 0.45),
      inset 0 0 12px rgba(255, 90, 77, 0.08);
    cursor: pointer;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      color 0.15s ease,
      background 0.15s ease;
    position: relative;
    z-index: 3;
    width: 100%;
    margin-top: clamp(5px, 0.8vh, 10px);
    text-shadow: 1px 1px 0 #0a0c14, 0 0 6px rgba(255, 157, 60, 0.6);
  }
  .ms-btn:hover {
    transform: translateY(-3px) scale(1.04);
    color: #fff2e6;
    background: rgba(255, 90, 40, 0.18);
    box-shadow:
      0 0 30px rgba(255, 157, 60, 0.85),
      0 0 60px rgba(255, 90, 77, 0.5),
      inset 0 0 14px rgba(255, 157, 60, 0.15);
    text-shadow: 1px 1px 0 #0a0c14, 0 0 10px rgba(255, 200, 60, 1);
  }
  .ms-solo {
    border-color: rgba(255, 157, 60, 0.8);
  }
  .ms-solo:hover {
    border-color: rgba(255, 157, 60, 1);
  }
  .char-start {
    /* inherits ms-btn, width:100% already set above */
  }

  /* ─── Game Over overlay ──────────────────────────────── */
  .bomber-over {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    background: rgba(4, 6, 13, 0.84);
    font-family: 'Press Start 2P', Consolas, monospace;
  }
  .bomber-over[hidden] {
    display: none;
  }
  .over-stats {
    margin: 0;
    font-size: 13px;
    letter-spacing: 2px;
    color: #ffd23f;
    text-align: center;
    line-height: 1.8;
  }
</style>

<script>
  import { startBomber } from '@scripts/games/bomber/render/main';
  import type { CharacterId } from '@scripts/games/bomber/engine/types';

  const params = new URLSearchParams(location.search);
  const canvas = document.getElementById('bomber-canvas') as HTMLCanvasElement | null;
  const modeSelect = document.getElementById('mode-select');
  let started = false;

  function startWithChar(char: CharacterId): void {
    if (started || !canvas) return;
    started = true;
    modeSelect?.remove();
    startBomber(canvas, char).catch((err: unknown) => console.error('[bomber] start failed', err));
  }

  // Card START buttons
  modeSelect?.querySelectorAll<HTMLButtonElement>('.char-start').forEach((btn) => {
    btn.addEventListener('click', () => {
      const char = btn.dataset.char as CharacterId | undefined;
      startWithChar(char ?? 'lena');
    });
  });

  // ?char=lena|mira — explicit character autostart
  const charParam = params.get('char') as CharacterId | null;
  if (charParam === 'lena' || charParam === 'mira') {
    startWithChar(charParam);
  }

  // ?mode=solo — backward compat for e2e tests (autostarts lena)
  if (!started && params.get('mode') === 'solo') {
    startWithChar('lena');
  }
</script>
