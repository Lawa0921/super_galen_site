---
/**
 * /games/bomber — Dungeon Arcade: Dungeon Bomber
 * 模式：SOLO；全螢幕 PixiJS 遊戲頁，由頁底腳本載入並 code-split。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import { defaultLang, type Language } from '@i18n/index';
import { CHARACTERS } from '@scripts/games/bomber/engine/characters';

const lang: Language = defaultLang;

const chars = [CHARACTERS.lena, CHARACTERS.mira];

// Role labels for each character (hardcoded, two-only)
const roleLabels: Record<string, string> = {
  lena: '工兵 / 坦',
  mira: '魔女 / 爆發',
};

// Per-stat caps for bar scaling
const barMax = { lives: 5, maxBombs: 8, fireRange: 8, speedLevel: 4 };

type StatKey = keyof typeof barMax;

const statRows: { key: StatKey; label: string; icon: string }[] = [
  { key: 'lives',      label: '命',   icon: 'ic-life' },
  { key: 'maxBombs',   label: '炸彈', icon: 'ic-bomb' },
  { key: 'fireRange',  label: '火力', icon: 'ic-fire' },
  { key: 'speedLevel', label: '速度', icon: 'ic-speed' },
];
---

<BaseLayout
  title="Dungeon Arcade — Dungeon Bomber"
  description="像素地城炸彈生存"
  lang={lang}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
  />

  <main class="bomber-page">
    <a class="bomber-back" href="/games">← ARCADE</a>
    <p class="bomber-hint">MOVE WASD/←→↑↓ · BOMB SPACE · MUTE M</p>
    <div class="bomber-stage">
      <canvas id="bomber-canvas"></canvas>
    </div>

    <div class="mode-select" id="mode-select">
      <h2 class="ms-title">SELECT YOUR BOMBER</h2>
      <div class="char-cards">
        {chars.map((profile) => {
          const id = profile.id;
          const role = roleLabels[id] ?? '';
          return (
            <div class="char-card">
              <img
                src={`/assets/games/bomber/portraits/${id}.png`}
                alt={profile.name}
                width="160"
                height="160"
                class="char-portrait"
                style="image-rendering:pixelated"
              />
              <div class="char-name">{profile.name}</div>
              <div class="char-role">{role}</div>
              <div class="char-stats">
                {statRows.map(({ key, label, icon }) => {
                  const startVal = profile.start[key];
                  const capVal   = profile.caps[key];
                  const max      = barMax[key];
                  const startPct = Math.round((startVal / max) * 100);
                  const capPct   = Math.round((capVal   / max) * 100);
                  const fadedPct = capPct - startPct;
                  return (
                    <div class="stat-row">
                      <img
                        class="stat-icon"
                        src={`/assets/games/bomber/ui/${icon}.png`}
                        alt={label}
                        title={label}
                        width="20"
                        height="20"
                      />
                      <div class="stat-bar-bg">
                        <div class="stat-bar-solid"   style={`width:${startPct}%`}></div>
                        <div class="stat-bar-faded"   style={`width:${fadedPct}%`}></div>
                      </div>
                    </div>
                  );
                })}
              </div>
              <button class="ms-btn ms-solo char-start" data-char={id}>▶ START</button>
            </div>
          );
        })}
      </div>
    </div>

    <div class="bomber-over" id="bomber-over" hidden>
      <h2 class="ms-title">GAME OVER</h2>
      <p id="bomber-over-stats" class="over-stats"></p>
      <button class="ms-btn ms-solo" id="bomber-restart">RETRY</button>
    </div>
  </main>
</BaseLayout>

<style>
  .bomber-page {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background: #06070f;
    overflow: hidden;
  }
  .bomber-stage {
    position: absolute;
    inset: 0;
  }
  #bomber-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .bomber-back {
    position: absolute;
    top: 18px;
    left: 20px;
    z-index: 10;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: #c98f6a;
    text-decoration: none;
    opacity: 0.8;
  }
  .bomber-back:hover {
    opacity: 1;
    color: #ff9d3c;
  }
  .bomber-hint {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    z-index: 10;
    margin: 0;
    text-align: center;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: #c98f6a;
    opacity: 0.75;
    pointer-events: none;
  }
  .mode-select {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
    background:
      linear-gradient(rgba(4, 6, 13, 0.78), rgba(4, 6, 13, 0.93)),
      url('/assets/games/bomber/ui/select-bg.png') center / cover no-repeat;
    image-rendering: pixelated;
    font-family: 'Press Start 2P', Consolas, monospace;
    padding: 20px;
    box-sizing: border-box;
  }
  .mode-select[hidden] {
    display: none;
  }
  .ms-title {
    margin: 0;
    font-size: clamp(14px, 2.8vw, 26px);
    letter-spacing: 4px;
    color: #fff2e6;
    text-shadow: 0 0 12px rgba(255, 157, 60, 0.9), 0 0 28px rgba(255, 157, 60, 0.5);
  }

  /* Character cards row */
  .char-cards {
    display: flex;
    flex-direction: row;
    gap: clamp(16px, 3vw, 40px);
    align-items: flex-start;
    justify-content: center;
    flex-wrap: wrap;
  }
  .char-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    background:
      linear-gradient(rgba(14, 10, 8, 0.92), rgba(8, 6, 12, 0.94));
    border: 2px solid rgba(255, 157, 60, 0.5);
    border-radius: 12px;
    padding: 20px 24px 24px;
    width: min(230px, 44vw);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.55), inset 0 0 0 1px rgba(255, 157, 60, 0.12);
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .char-card:hover {
    border-color: rgba(255, 157, 60, 0.9);
    box-shadow: 0 0 24px rgba(255, 157, 60, 0.4);
    transform: translateY(-4px);
  }
  .char-portrait {
    display: block;
    width: clamp(100px, 18vw, 160px);
    height: auto;
    border: 3px solid rgba(255, 157, 60, 0.55);
    border-radius: 6px;
    background: rgba(6, 8, 14, 0.6);
    box-shadow: inset 0 0 0 2px rgba(0, 0, 0, 0.5), 0 4px 14px rgba(0, 0, 0, 0.5);
    /* image-rendering set inline (pixelated) */
  }
  .char-name {
    font-size: clamp(13px, 2vw, 18px);
    letter-spacing: 3px;
    color: #fff2e6;
  }
  .char-role {
    font-size: clamp(8px, 1.2vw, 10px);
    letter-spacing: 1px;
    color: #c98f6a;
  }

  /* Stat bars */
  .char-stats {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 4px;
  }
  .stat-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .stat-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    image-rendering: pixelated;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.6));
  }
  .stat-bar-bg {
    flex: 1;
    height: 8px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
  }
  .stat-bar-solid {
    height: 100%;
    background: #ff9d3c;
    border-radius: 4px 0 0 4px;
  }
  .stat-bar-faded {
    height: 100%;
    background: rgba(255, 157, 60, 0.25);
  }

  /* Start button */
  .ms-btn {
    padding: 14px 20px;
    font-family: inherit;
    font-size: 11px;
    letter-spacing: 2px;
    color: #ffe9d6;
    background: rgba(8, 12, 22, 0.8);
    border: 2px solid rgba(255, 157, 60, 0.7);
    border-radius: 10px;
    box-shadow: 0 0 12px rgba(255, 157, 60, 0.3);
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, color 0.15s ease;
  }
  .ms-btn:hover {
    transform: translateY(-3px);
    color: #fff2e6;
    box-shadow: 0 0 22px rgba(255, 157, 60, 0.75);
  }
  .ms-solo {
    border-color: rgba(255, 157, 60, 0.7);
    box-shadow: 0 0 12px rgba(255, 90, 77, 0.4);
  }
  .ms-solo:hover {
    box-shadow: 0 0 22px rgba(255, 90, 77, 0.85);
  }
  .char-start {
    margin-top: 6px;
    width: 100%;
  }

  /* 遊戲結束 overlay：同 mode-select 樣式 */
  .bomber-over {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    background: rgba(4, 6, 13, 0.84);
    font-family: 'Press Start 2P', Consolas, monospace;
  }
  .bomber-over[hidden] {
    display: none;
  }
  .over-stats {
    margin: 0;
    font-size: 13px;
    letter-spacing: 2px;
    color: #ffd23f;
    text-align: center;
    line-height: 1.8;
  }
</style>

<script>
  import { startBomber } from '@scripts/games/bomber/render/main';
  import type { CharacterId } from '@scripts/games/bomber/engine/types';

  const params = new URLSearchParams(location.search);
  const canvas = document.getElementById('bomber-canvas') as HTMLCanvasElement | null;
  const modeSelect = document.getElementById('mode-select');
  let started = false;

  function startWithChar(char: CharacterId): void {
    if (started || !canvas) return;
    started = true;
    modeSelect?.remove();
    startBomber(canvas, char).catch((err: unknown) => console.error('[bomber] start failed', err));
  }

  // Card START buttons
  modeSelect?.querySelectorAll<HTMLButtonElement>('.char-start').forEach((btn) => {
    btn.addEventListener('click', () => {
      const char = btn.dataset.char as CharacterId | undefined;
      startWithChar(char ?? 'lena');
    });
  });

  // ?char=lena|mira — explicit character autostart
  const charParam = params.get('char') as CharacterId | null;
  if (charParam === 'lena' || charParam === 'mira') {
    startWithChar(charParam);
  }

  // ?mode=solo — backward compat for e2e tests (autostarts lena)
  if (!started && params.get('mode') === 'solo') {
    startWithChar('lena');
  }
</script>
