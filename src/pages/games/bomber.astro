  .vs-glow-ring {
    position: absolute;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 157, 60, 0.35) 0%,
      rgba(255, 90, 77, 0.2) 55%,
      transparent 100%
    );
    border: 2px solid rgba(255, 157, 60, 0.7);
    box-shadow:
      0 0 16px rgba(255, 157, 60, 0.8),
      0 0 32px rgba(255, 90, 77, 0.5),
      inset 0 0 10px rgba(255, 157, 60, 0.25);
    animation: emblem-pulse 1.8s ease-in-out infinite;
  }
  @keyframes emblem-pulse {
    0%, 100% {
      box-shadow:
        0 0 16px rgba(255, 157, 60, 0.8),
