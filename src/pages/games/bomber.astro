---
/**
 * /games/bomber — Dungeon Arcade: Dungeon Bomber
 * Layout B: Cinematic hero-stage select (4 characters, roster panel)
 * 模式：SOLO；全螢幕 PixiJS 遊戲頁，由頁底腳本載入並 code-split。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import { defaultLang, type Language } from '@i18n/index';
import { CHARACTERS } from '@scripts/games/bomber/engine/characters';

const lang: Language = defaultLang;

const chars = [CHARACTERS.lena, CHARACTERS.mira, CHARACTERS.aya, CHARACTERS.rosa];

const roleLabels: Record<string, string> = {
  lena: '工兵 / 坦',
  mira: '魔女 / 爆發',
  aya:  '斥候 / 高速',
  rosa: '隊長 / 重裝',
};

// Per-stat caps for bar scaling
const barMax = { lives: 5, maxBombs: 8, fireRange: 8, speedLevel: 4 };

type StatKey = keyof typeof barMax;

const statRows: { key: StatKey; label: string; icon: string }[] = [
  { key: 'lives',      label: '命',   icon: 'ic-life' },
  { key: 'maxBombs',   label: '炸彈', icon: 'ic-bomb' },
  { key: 'fireRange',  label: '火力', icon: 'ic-fire' },
  { key: 'speedLevel', label: '速度', icon: 'ic-speed' },
];
---

<BaseLayout
  title="Dungeon Arcade — Dungeon Bomber"
  description="像素地城炸彈生存"
  lang={lang}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
  />

  <main class="bomber-page">
    <a class="bomber-back" href="/games">← ARCADE</a>
    <p class="bomber-hint">MOVE WASD/←→↑↓ · BOMB SPACE · MUTE M</p>
    <div class="bomber-stage">
      <canvas id="bomber-canvas"></canvas>
    </div>

    <!-- ── Mode Select — Layout B: Cinematic Hero Stage ── -->
    <div class="mode-select" id="mode-select">
      <!-- CRT scanline + vignette overlay -->
      <div class="crt-overlay" aria-hidden="true"></div>

      <!-- Outer arcade bezel frame corners -->
      <div class="bezel-corner bezel-corner--tl" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--tr" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--bl" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--br" aria-hidden="true"></div>

      <!-- Title bar (full width, top) -->
      <div class="ms-header">
        <h2 class="ms-title">SELECT YOUR BOMBER</h2>
        <p class="ms-subtitle">▶ PRESS START</p>
      </div>

      <!-- ── Main Stage Area ── -->
      <div class="stage-area">

        <!-- Hero panels (one per character, only active one is visible) -->
        <div class="hero-stage">
          {chars.map((profile, idx) => {
            const id = profile.id;
            const role = roleLabels[id] ?? '';
            return (
              <div
                class={`hero-panel${idx === 0 ? ' is-active' : ''}`}
                data-char-panel={id}
              >
                <!-- Warm radial spotlight behind standee -->
                <div class="hero-spotlight" aria-hidden="true"></div>

                <!-- Full-body standee on the flame pedestal -->
                <img
                  src={`/assets/games/bomber/portraits/${id}-full.png`}
                  alt={profile.name}
                  class="hero-standee"
                  style="image-rendering:pixelated"
                />

                <!-- Pulsing flame glow ellipse at feet (pedestal glow) -->
                <div class="hero-flame-glow" aria-hidden="true"></div>

                <!-- Name + role label -->
                <div class="hero-nameplate">
                  <div class="hero-name">{profile.name}</div>
                  <div class="hero-role">{role}</div>
                </div>

                <!-- Stat gauges panel -->
                <div class="hero-stats">
                  {statRows.map(({ key, label, icon }) => {
                    const startVal = profile.start[key];
                    const capVal   = profile.caps[key];
                    const max      = barMax[key];
                    const pips = Array.from({ length: max }, (_, i) => {
                      if (i < startVal) return 'solid';
                      if (i < capVal)   return 'growth';
                      return 'empty';
                    });
                    return (
                      <div class="stat-row">
                        <img
                          class="stat-icon"
                          src={`/assets/games/bomber/ui/${icon}.png`}
                          alt={label}
                          title={label}
                          width="18"
                          height="18"
                          style="image-rendering:pixelated"
                        />
                        <div class="stat-pips">
                          {pips.map((kind) => (
                            <span class={`pip pip--${kind}`}></span>
                          ))}
                        </div>
                        <span class="stat-val">
                          <span class="stat-num">{startVal}</span>
                          <span class="arrow">→</span>
                          <span class="stat-num stat-num--cap">{capVal}</span>
                        </span>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>

        <!-- Roster panel (right column) -->
        <div class="roster">
          <div class="roster-label" aria-hidden="true">ROSTER</div>
          {chars.map((profile, idx) => {
            const id = profile.id;
            const role = roleLabels[id] ?? '';
            return (
              <button
                class={`roster-item${idx === 0 ? ' is-selected' : ''}`}
                data-char={id}
                type="button"
              >
                <img
                  src={`/assets/games/bomber/portraits/${id}-full.png`}
                  alt={profile.name}
                  class="roster-thumb"
                  style="image-rendering:pixelated"
                />
                <div class="roster-info">
                  <span class="roster-name">{profile.name}</span>
                  <span class="roster-role">{role}</span>
                </div>
                <div class="roster-sel-bar" aria-hidden="true"></div>
              </button>
            );
          })}

          <!-- START button in roster panel -->
          <button class="ms-btn ms-solo roster-start" data-action="start" type="button">
            ▶ START
          </button>
        </div>

      </div><!-- /stage-area -->
    </div><!-- /mode-select -->

    <div class="bomber-over" id="bomber-over" hidden>
      <h2 class="ms-title">GAME OVER</h2>
      <p id="bomber-over-stats" class="over-stats"></p>
      <button class="ms-btn ms-solo" id="bomber-restart">RETRY</button>
    </div>
  </main>
</BaseLayout>

<style>
  /* ─── Page shell ─────────────────────────────────────── */
  .bomber-page {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background: #0a0c14;
    overflow: hidden;
  }
  .bomber-stage {
    position: absolute;
    inset: 0;
  }
  #bomber-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .bomber-back {
    position: absolute;
    top: 18px;
    left: 20px;
    z-index: 30;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: #c98f6a;
    text-decoration: none;
    opacity: 0.8;
  }
  .bomber-back:hover {
    opacity: 1;
    color: #ff9d3c;
  }
  .bomber-hint {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    z-index: 30;
    margin: 0;
    text-align: center;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: #c98f6a;
    opacity: 0.75;
    pointer-events: none;
  }

  /* ─── Mode-select full-screen (Layout B) ─────────────── */
  .mode-select {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    font-family: 'Press Start 2P', Consolas, monospace;
    /* Hero-bg: dungeon stage with flame pedestal spotlight */
    background:
      url('/assets/games/bomber/ui/hero-bg.png') center / cover no-repeat;
    image-rendering: pixelated;
    overflow: hidden;
  }
  .mode-select[hidden] {
    display: none;
  }

  /* ─── CRT overlay (scanlines + vignette + flicker) ───── */
  .crt-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    background:
      repeating-linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0) 0px,
        rgba(0, 0, 0, 0) 2px,
        rgba(0, 0, 0, 0.15) 2px,
        rgba(0, 0, 0, 0.15) 3px
      ),
      radial-gradient(
        ellipse 92% 82% at 50% 50%,
        rgba(0, 0, 0, 0) 25%,
        rgba(4, 5, 14, 0.42) 65%,
        rgba(4, 5, 14, 0.72) 100%
      );
    animation: crt-flicker 5s steps(1) infinite;
  }
  @keyframes crt-flicker {
    0%,  94%, 96%, 100% { opacity: 1; }
    95% { opacity: 0.91; }
  }

  /* ─── Bezel corner accents ───────────────────────────── */
  .bezel-corner {
    position: absolute;
    z-index: 48;
    width: 28px;
    height: 28px;
    pointer-events: none;
    border-color: #ff9d3c;
    border-style: solid;
    opacity: 0.75;
  }
  .bezel-corner--tl { top: 6px; left: 6px;   border-width: 3px 0 0 3px; }
  .bezel-corner--tr { top: 6px; right: 6px;  border-width: 3px 3px 0 0; }
  .bezel-corner--bl { bottom: 6px; left: 6px;  border-width: 0 0 3px 3px; }
  .bezel-corner--br { bottom: 6px; right: 6px; border-width: 0 3px 3px 0; }

  /* ─── Header / Title bar ─────────────────────────────── */
  .ms-header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding-top: clamp(10px, 1.8vh, 22px);
    padding-bottom: clamp(4px, 0.8vh, 12px);
    border-bottom: 3px solid rgba(255, 157, 60, 0.55);
    width: 100%;
    background: linear-gradient(
      to bottom,
      rgba(4, 5, 14, 0.92) 0%,
      rgba(4, 5, 14, 0.3) 100%
    );
    box-shadow: 0 3px 18px rgba(255, 157, 60, 0.22);
    flex-shrink: 0;
  }
  .ms-title {
    margin: 0;
    font-size: clamp(14px, 2.6vw, 30px);
    letter-spacing: clamp(3px, 0.7vw, 7px);
    color: #fff2e6;
    text-shadow:
      4px 4px 0 #0a0c14,
      -2px -2px 0 #0a0c14,
      0 0 10px rgba(255, 157, 60, 1),
      0 0 28px rgba(255, 157, 60, 0.7),
      0 0 60px rgba(255, 90, 77, 0.4);
  }
  .ms-subtitle {
    margin: clamp(4px, 0.6vh, 8px) 0 0;
    font-size: clamp(7px, 1vw, 9px);
    letter-spacing: 2px;
    color: #ff9d3c;
    animation: blink-press 1s steps(1) infinite;
  }
  @keyframes blink-press {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* ─── Stage area: hero stage (left) + roster (right) ─── */
  .stage-area {
    display: flex;
    flex-direction: row;
    flex: 1 1 auto;
    min-height: 0;
    position: relative;
    z-index: 5;
    /* Semi-transparent dark layer over hero-bg for the whole stage area */
    background: rgba(4, 5, 14, 0.25);
  }

  /* ─── Hero stage panel (left/center, ~72% width) ─────── */
  .hero-stage {
    flex: 1 1 auto;
    min-width: 0;
    position: relative;
    overflow: hidden;
  }

  /* Hero panels: only .is-active is visible */
  .hero-panel {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: clamp(12px, 2vh, 28px) clamp(12px, 2vw, 32px);
    box-sizing: border-box;
  }
  .hero-panel.is-active {
    display: flex;
  }

  /* Radial spotlight behind standee upper body */
  .hero-spotlight {
    position: absolute;
    /* Spotlight originates from the left-of-center column (pedestal area) */
    left: 12%;
    top: -5%;
    width: 58%;
    height: 90%;
    background: radial-gradient(
      ellipse 55% 65% at 46% 42%,
      rgba(255, 210, 130, 0.18) 0%,
      rgba(255, 157, 60, 0.10) 40%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
    animation: spotlight-breathe 3.2s ease-in-out infinite;
  }
  @keyframes spotlight-breathe {
    0%, 100% { opacity: 0.75; }
    50% { opacity: 1; }
  }

  /* Full-body standee — stands on the pedestal */
  .hero-standee {
    /* Left-of-center, anchored to bottom */
    position: absolute;
    left: 38%;
    transform: translateX(-50%);
    bottom: clamp(60px, 14vh, 140px);
    height: clamp(260px, 56vh, 560px);
    width: auto;
    object-fit: contain;
    z-index: 3;
    filter:
      drop-shadow(0 6px 24px rgba(0, 0, 0, 0.9))
      drop-shadow(0 0 10px rgba(255, 157, 60, 0.45))
      drop-shadow(0 0 28px rgba(255, 90, 77, 0.25));
    animation: idle-bob 2.2s ease-in-out infinite;
  }
  @keyframes idle-bob {
    0%, 100% { transform: translateX(-50%) translateY(0px); }
    50%       { transform: translateX(-50%) translateY(-6px); }
  }

  /* Pulsing flame-glow ellipse at feet (enhances pedestal flames in bg) */
  .hero-flame-glow {
    position: absolute;
    left: 38%;
    transform: translateX(-50%);
    bottom: clamp(55px, 12vh, 120px);
    width: clamp(100px, 18vw, 220px);
    height: clamp(20px, 4vh, 48px);
    background: radial-gradient(
      ellipse at 50% 100%,
      rgba(255, 100, 30, 0.75) 0%,
      rgba(255, 157, 60, 0.45) 40%,
      rgba(255, 90, 77, 0.15) 70%,
      transparent 100%
    );
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    animation: flame-pulse 1.6s ease-in-out infinite;
  }
  @keyframes flame-pulse {
    0%, 100% { opacity: 0.7; transform: translateX(-50%) scaleX(1); }
    50%       { opacity: 1;   transform: translateX(-50%) scaleX(1.18); }
  }

  /* Name + role below standee — bottom-left area of hero stage */
  .hero-nameplate {
    position: relative;
    z-index: 4;
    padding: clamp(6px, 1vh, 12px) clamp(10px, 1.5vw, 20px);
    background: rgba(6, 4, 16, 0.88);
    border: 2px solid rgba(255, 157, 60, 0.8);
    clip-path: polygon(
      0 8px, 8px 0,
      calc(100% - 8px) 0, 100% 8px,
      100% calc(100% - 6px), calc(100% - 6px) 100%,
      6px 100%, 0 calc(100% - 8px)
    );
    box-shadow: 0 0 18px rgba(255, 157, 60, 0.32);
    margin-bottom: clamp(6px, 1vh, 14px);
  }
  .hero-name {
    font-size: clamp(16px, 2.4vw, 28px);
    letter-spacing: 3px;
    color: #fff2e6;
    text-shadow:
      2px 2px 0 #0a0c14,
      0 0 8px rgba(255, 157, 60, 0.9),
      0 0 22px rgba(255, 157, 60, 0.5);
  }
  .hero-role {
    margin-top: 4px;
    font-size: clamp(7px, 0.95vw, 9px);
    letter-spacing: 1.5px;
    color: #c98f6a;
  }

  /* Stat gauges — below nameplate, in opaque dark panel */
  .hero-stats {
    display: flex;
    flex-direction: column;
    gap: clamp(4px, 0.7vh, 8px);
    position: relative;
    z-index: 4;
    background: rgba(6, 4, 16, 0.82);
    border: 2px solid rgba(255, 157, 60, 0.45);
    border-radius: 0;
    padding: clamp(6px, 1vh, 12px) clamp(8px, 1.2vw, 16px);
    box-shadow: 0 0 12px rgba(255, 90, 77, 0.12);
  }
  .stat-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .stat-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.8));
  }
  .stat-pips {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 3px;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  .pip {
    display: inline-block;
    width: clamp(7px, 1.2vw, 14px);
    height: clamp(7px, 1.2vh, 12px);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .pip--solid {
    background: linear-gradient(180deg, #ffda6b 0%, #ff8c1a 100%);
    box-shadow:
      0 0 4px rgba(255, 157, 60, 0.9),
      0 0 8px rgba(255, 157, 60, 0.5),
      inset 0 1px 0 rgba(255, 255, 180, 0.4);
    border: 1px solid rgba(255, 200, 60, 0.6);
  }
  .pip--growth {
    background: rgba(255, 130, 40, 0.18);
    border: 1px solid rgba(255, 157, 60, 0.45);
    box-shadow: 0 0 3px rgba(255, 157, 60, 0.2);
  }
  .pip--empty {
    background: rgba(10, 12, 20, 0.6);
    border: 1px solid rgba(80, 60, 40, 0.4);
  }
  .stat-val {
    flex-shrink: 0;
    font-size: clamp(7px, 0.85vw, 9px);
    letter-spacing: 0;
    color: #ffd7a8;
    text-align: right;
    min-width: 34px;
  }
  .stat-num { color: #ffd23f; }
  .stat-num--cap { color: #ff9d3c; }
  .arrow { color: #c98f6a; margin: 0 1px; }

  /* ─── Roster panel (right column, ~28% width) ────────── */
  .roster {
    flex: 0 0 clamp(160px, 26vw, 300px);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(4px, 0.6vh, 8px);
    padding: clamp(8px, 1.4vh, 18px) clamp(8px, 1.2vw, 16px);
    box-sizing: border-box;
    background: rgba(4, 5, 14, 0.76);
    border-left: 3px solid rgba(255, 157, 60, 0.45);
    box-shadow: inset 2px 0 24px rgba(0, 0, 0, 0.38);
    overflow-y: auto;
  }

  .roster-label {
    font-size: clamp(7px, 0.9vw, 8px);
    letter-spacing: 3px;
    color: rgba(255, 157, 60, 0.5);
    text-align: center;
    padding-bottom: clamp(4px, 0.6vh, 8px);
    border-bottom: 1px solid rgba(255, 157, 60, 0.25);
    margin-bottom: clamp(2px, 0.4vh, 6px);
    flex-shrink: 0;
  }

  /* Individual roster item */
  .roster-item {
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: clamp(6px, 1vw, 10px);
    padding: clamp(6px, 1vh, 10px) clamp(8px, 1vw, 12px);
    background: rgba(8, 6, 18, 0.7);
    border: 2px solid rgba(255, 157, 60, 0.3);
    box-sizing: border-box;
    cursor: pointer;
    text-align: left;
    font-family: 'Press Start 2P', Consolas, monospace;
    transition:
      border-color 0.14s ease,
      background 0.14s ease,
      transform 0.14s ease,
      box-shadow 0.14s ease;
    overflow: hidden;
    flex-shrink: 0;
  }
  .roster-item:hover {
    border-color: rgba(255, 157, 60, 0.7);
    background: rgba(255, 100, 30, 0.08);
    transform: translateX(-3px);
    box-shadow: 2px 0 14px rgba(255, 157, 60, 0.28);
  }
  .roster-item:focus-visible {
    outline: none;
    border-color: #ffd23f;
    box-shadow: 0 0 0 2px rgba(255, 210, 63, 0.4);
  }
  .roster-item.is-selected {
    border-color: #ff9d3c;
    background: rgba(255, 100, 20, 0.14);
    transform: translateX(-4px) scale(1.02);
    box-shadow:
      3px 0 20px rgba(255, 157, 60, 0.55),
      inset 0 0 16px rgba(255, 90, 30, 0.1);
  }

  /* Left amber edge bar for selected state */
  .roster-sel-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, #ffd23f, #ff5a4d);
    opacity: 0;
    transition: opacity 0.14s ease;
  }
  .roster-item.is-selected .roster-sel-bar {
    opacity: 1;
    box-shadow: 0 0 8px rgba(255, 157, 60, 0.9);
  }

  /* Roster thumbnail (~64px tall) */
  .roster-thumb {
    height: clamp(44px, 8vh, 72px);
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.75));
    transition: filter 0.14s ease;
  }
  .roster-item.is-selected .roster-thumb {
    filter:
      drop-shadow(0 2px 8px rgba(0, 0, 0, 0.85))
      drop-shadow(0 0 8px rgba(255, 157, 60, 0.6));
  }

  /* Roster name + role text */
  .roster-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .roster-name {
    font-size: clamp(9px, 1.1vw, 12px);
    letter-spacing: 1px;
    color: #fff2e6;
    text-shadow: 1px 1px 0 #0a0c14;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .roster-item.is-selected .roster-name {
    color: #ffd23f;
    text-shadow: 1px 1px 0 #0a0c14, 0 0 6px rgba(255, 210, 63, 0.7);
  }
  .roster-role {
    font-size: clamp(6px, 0.7vw, 7px);
    letter-spacing: 0.5px;
    color: #c98f6a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* START button (in roster panel) */
  .ms-btn {
    padding: clamp(10px, 1.5vh, 16px) clamp(12px, 1.5vw, 22px);
    font-family: inherit;
    font-size: clamp(9px, 1.1vw, 12px);
    letter-spacing: 2px;
    color: #ffe9d6;
    background: rgba(8, 12, 22, 0.88);
    border: 3px solid rgba(255, 157, 60, 0.8);
    border-radius: 0;
    clip-path: polygon(
      0 6px, 6px 0,
      calc(100% - 6px) 0, 100% 6px,
      100% calc(100% - 6px), calc(100% - 6px) 100%,
      6px 100%, 0 calc(100% - 6px)
    );
    box-shadow:
      0 0 14px rgba(255, 157, 60, 0.45),
      inset 0 0 12px rgba(255, 90, 77, 0.08);
    cursor: pointer;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
    position: relative;
    z-index: 5;
    width: 100%;
    text-shadow: 1px 1px 0 #0a0c14, 0 0 6px rgba(255, 157, 60, 0.6);
  }
  .ms-btn:hover {
    transform: translateY(-3px) scale(1.04);
    color: #fff2e6;
    background: rgba(255, 90, 40, 0.18);
    box-shadow:
      0 0 30px rgba(255, 157, 60, 0.85),
      0 0 60px rgba(255, 90, 77, 0.5),
      inset 0 0 14px rgba(255, 157, 60, 0.15);
    text-shadow: 1px 1px 0 #0a0c14, 0 0 10px rgba(255, 200, 60, 1);
    border-color: #ff9d3c;
  }
  .ms-solo { border-color: rgba(255, 157, 60, 0.8); }
  .ms-solo:hover { border-color: rgba(255, 157, 60, 1); }

  .roster-start {
    margin-top: auto;
    flex-shrink: 0;
  }

  /* ─── Game Over overlay ──────────────────────────────── */
  .bomber-over {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    background: rgba(4, 6, 13, 0.84);
    font-family: 'Press Start 2P', Consolas, monospace;
  }
  .bomber-over[hidden] {
    display: none;
  }
  .over-stats {
    margin: 0;
    font-size: 13px;
    letter-spacing: 2px;
    color: #ffd23f;
    text-align: center;
    line-height: 1.8;
  }
</style>

<script>
  import { startBomber } from '@scripts/games/bomber/render/main';
  import type { CharacterId } from '@scripts/games/bomber/engine/types';

  const VALID_CHARS: CharacterId[] = ['lena', 'mira', 'aya', 'rosa'];

  const params = new URLSearchParams(location.search);
  const canvas = document.getElementById('bomber-canvas') as HTMLCanvasElement | null;
  const modeSelect = document.getElementById('mode-select');
  let started = false;

  // ── Selection state ──────────────────────────────────────
  let selected: CharacterId = 'lena';

  function setSelected(id: CharacterId): void {
    selected = id;

    // Toggle hero panels
    document.querySelectorAll<HTMLElement>('[data-char-panel]').forEach((panel) => {
      panel.classList.toggle('is-active', panel.dataset.charPanel === id);
    });

    // Toggle roster items
    document.querySelectorAll<HTMLElement>('[data-char]').forEach((item) => {
      if (item.tagName === 'BUTTON') {
        item.classList.toggle('is-selected', item.dataset.char === id);
      }
    });
  }

  // ── Start game ───────────────────────────────────────────
  function start(id: CharacterId): void {
    if (started || !canvas) return;
    started = true;
    modeSelect?.remove();
    startBomber(canvas, id).catch((err: unknown) => console.error('[bomber] start failed', err));
  }

  // ── Roster item clicks ───────────────────────────────────
  modeSelect?.querySelectorAll<HTMLButtonElement>('.roster-item').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.char as CharacterId | undefined;
      if (id && (VALID_CHARS as string[]).includes(id)) setSelected(id);
    });
  });

  // ── START button click ───────────────────────────────────
  modeSelect?.querySelector<HTMLButtonElement>('[data-action="start"]')?.addEventListener('click', () => {
    start(selected);
  });

  // ── Keyboard navigation ──────────────────────────────────
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (started) return;
    const idx = VALID_CHARS.indexOf(selected);
    if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
      e.preventDefault();
      setSelected(VALID_CHARS[(idx + 1) % VALID_CHARS.length]);
    } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
      e.preventDefault();
      setSelected(VALID_CHARS[(idx + VALID_CHARS.length - 1) % VALID_CHARS.length]);
    } else if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      start(selected);
    }
  });

  // ── Initialize selection UI ──────────────────────────────
  setSelected(selected);

  // ── Autostart: ?char= one of the 4 ──────────────────────
  const charParam = params.get('char') as CharacterId | null;
  if (charParam && (VALID_CHARS as string[]).includes(charParam)) {
    start(charParam);
  }

  // ── Autostart: ?mode=solo → lena (backward compat for e2e) ──
  if (!started && params.get('mode') === 'solo') {
    start('lena');
  }
</script>
