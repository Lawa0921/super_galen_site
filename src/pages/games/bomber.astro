---
/**
 * /games/bomber — Dungeon Arcade: Dungeon Bomber
 * 模式：SOLO；全螢幕 PixiJS 遊戲頁，由頁底腳本載入並 code-split。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import { defaultLang, type Language } from '@i18n/index';
import { CHARACTERS } from '@scripts/games/bomber/engine/characters';

const lang: Language = defaultLang;

const chars = [CHARACTERS.lena, CHARACTERS.mira];

// Role labels for each character (hardcoded, two-only)
const roleLabels: Record<string, string> = {
  lena: '工兵 / 坦',
  mira: '魔女 / 爆發',
};

// Per-stat caps for bar scaling
const barMax = { lives: 5, maxBombs: 8, fireRange: 8, speedLevel: 4 };

type StatKey = keyof typeof barMax;

const statRows: { key: StatKey; label: string; icon: string }[] = [
  { key: 'lives',      label: '命',   icon: 'ic-life' },
  { key: 'maxBombs',   label: '炸彈', icon: 'ic-bomb' },
  { key: 'fireRange',  label: '火力', icon: 'ic-fire' },
  { key: 'speedLevel', label: '速度', icon: 'ic-speed' },
];
---

<BaseLayout
  title="Dungeon Arcade — Dungeon Bomber"
  description="像素地城炸彈生存"
  lang={lang}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
  />

  <main class="bomber-page">
    <a class="bomber-back" href="/games">← ARCADE</a>
    <p class="bomber-hint">MOVE WASD/←→↑↓ · BOMB SPACE · MUTE M</p>
    <div class="bomber-stage">
      <canvas id="bomber-canvas"></canvas>
    </div>

    <div class="mode-select" id="mode-select">
      <!-- CRT scanline + vignette overlay -->
      <div class="crt-overlay" aria-hidden="true"></div>

      <!-- Outer arcade bezel frame corners -->
      <div class="bezel-corner bezel-corner--tl" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--tr" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--bl" aria-hidden="true"></div>
      <div class="bezel-corner bezel-corner--br" aria-hidden="true"></div>

      <!-- Title bar (full width, top) -->
      <div class="ms-header">
        <h2 class="ms-title">SELECT YOUR BOMBER</h2>
        <p class="ms-subtitle">▶ PRESS START</p>
      </div>

      <!-- Two character STAGES -->
      <div class="char-cards">
        {chars.map((profile, idx) => {
          const id = profile.id;
          const role = roleLabels[id] ?? '';
          return (
            <div class={`char-card char-card--${id}`} data-idx={idx}>

              <!-- Big themed art block — full panel fill -->
              <div
                class="char-block"
                style={`background-image:url('/assets/games/bomber/ui/block-${id}.png');image-rendering:pixelated`}
                aria-hidden="true"
              >
                <!-- Gradient overlay darkening the bottom third for legibility -->
                <div class="char-block-grad" aria-hidden="true"></div>
              </div>

              <!-- Radial spotlight behind upper body -->
              <div class="spotlight-radial" aria-hidden="true"></div>

              <!-- Full-body standee — breaks out of frame at top -->
              <div class="char-figure">
                <img
                  src={`/assets/games/bomber/portraits/${id}-full.png`}
                  alt={profile.name}
                  class="char-fig-img"
                  style="image-rendering:pixelated"
                />
                <!-- Glow pool at feet -->
                <div class="ground-glow" aria-hidden="true"></div>
              </div>

              <!-- Angled name banner overlaid on the dark gradient zone -->
              <div class="char-banner">
                <div class="char-name">{profile.name}</div>
                <div class="char-role">{role}</div>
              </div>

              <!-- Segmented arcade stat gauges -->
              <div class="char-stats">
                {statRows.map(({ key, label, icon }) => {
                  const startVal = profile.start[key];
                  const capVal   = profile.caps[key];
                  const max      = barMax[key];
                  const pips = Array.from({ length: max }, (_, i) => {
                    if (i < startVal) return 'solid';
                    if (i < capVal)   return 'growth';
                    return 'empty';
                  });
                  return (
                    <div class="stat-row">
                      <img
                        class="stat-icon"
                        src={`/assets/games/bomber/ui/${icon}.png`}
                        alt={label}
                        title={label}
                        width="20"
                        height="20"
                        style="image-rendering:pixelated"
                      />
                      <div class="stat-pips">
                        {pips.map((kind) => (
                          <span class={`pip pip--${kind}`}></span>
                        ))}
                      </div>
                      <span class="stat-val">
                        <span class="stat-num">{startVal}</span>
                        <span class="arrow">→</span>
                        <span class="stat-num stat-num--cap">{capVal}</span>
                      </span>
                    </div>
                  );
                })}
              </div>

              <!-- START button -->
              <button class="ms-btn ms-solo char-start" data-char={id}>▶ START</button>
            </div>
          );
        })}

        <!-- ── Central divider / emblem ── -->
        <div class="divider-seam" aria-hidden="true">
          <!-- Decorative rivets -->
          <div class="rivet rivet--top"></div>
          <div class="rivet rivet--upper"></div>
          <!-- Central bomb emblem -->
          <div class="vs-emblem">
            <div class="vs-glow-ring" aria-hidden="true"></div>
            <img
              src="/assets/games/bomber/ui/ic-bomb.png"
              alt=""
              class="vs-bomb-icon"
              style="image-rendering:pixelated"
            />
          </div>
          <div class="rivet rivet--lower"></div>
          <div class="rivet rivet--bottom"></div>
        </div>
      </div>
    </div>

    <div class="bomber-over" id="bomber-over" hidden>
      <h2 class="ms-title">GAME OVER</h2>
      <p id="bomber-over-stats" class="over-stats"></p>
      <button class="ms-btn ms-solo" id="bomber-restart">RETRY</button>
    </div>
  </main>
</BaseLayout>

<style>
  /* ─── Page shell ─────────────────────────────────────── */
  .bomber-page {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background: #0a0c14;
    overflow: hidden;
  }
  .bomber-stage {
    position: absolute;
    inset: 0;
  }
  #bomber-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .bomber-back {
    position: absolute;
    top: 18px;
    left: 20px;
    z-index: 30;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: #c98f6a;
    text-decoration: none;
    opacity: 0.8;
  }
  .bomber-back:hover {
    opacity: 1;
    color: #ff9d3c;
  }
  .bomber-hint {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    z-index: 30;
    margin: 0;
    text-align: center;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: #c98f6a;
    opacity: 0.75;
    pointer-events: none;
  }

  /* ─── Mode-select full-screen ────────────────────────── */
  .mode-select {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    font-family: 'Press Start 2P', Consolas, monospace;
    background: #0a0c14;
    overflow: hidden;
  }
  .mode-select[hidden] {
    display: none;
  }

  /* ─── CRT overlay (scanlines + vignette + flicker) ───── */
  .crt-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 50;
    background:
      repeating-linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0) 0px,
        rgba(0, 0, 0, 0) 2px,
        rgba(0, 0, 0, 0.18) 2px,
        rgba(0, 0, 0, 0.18) 3px
      ),
      radial-gradient(
        ellipse 92% 82% at 50% 50%,
        rgba(0, 0, 0, 0) 25%,
        rgba(4, 5, 14, 0.45) 65%,
        rgba(4, 5, 14, 0.78) 100%
      );
    animation: crt-flicker 5s steps(1) infinite;
  }
  @keyframes crt-flicker {
    0%,  94%, 96%, 100% { opacity: 1; }
    95% { opacity: 0.91; }
  }

  /* ─── Bezel corner accents ───────────────────────────── */
  .bezel-corner {
    position: absolute;
    z-index: 48;
    width: 28px;
    height: 28px;
    pointer-events: none;
    border-color: #ff9d3c;
    border-style: solid;
    opacity: 0.75;
  }
  .bezel-corner--tl {
    top: 6px;
    left: 6px;
    border-width: 3px 0 0 3px;
  }
  .bezel-corner--tr {
    top: 6px;
    right: 6px;
    border-width: 3px 3px 0 0;
  }
  .bezel-corner--bl {
    bottom: 6px;
    left: 6px;
    border-width: 0 0 3px 3px;
  }
  .bezel-corner--br {
    bottom: 6px;
    right: 6px;
    border-width: 0 3px 3px 0;
  }

  /* ─── Header / Title bar ─────────────────────────────── */
  .ms-header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding-top: clamp(10px, 1.8vh, 22px);
    padding-bottom: clamp(4px, 0.8vh, 12px);
    border-bottom: 3px solid rgba(255, 157, 60, 0.55);
    width: 100%;
    background: linear-gradient(
      to bottom,
      rgba(4, 5, 14, 0.88) 0%,
      rgba(4, 5, 14, 0.32) 100%
    );
    /* Top amber line for the outer arcade frame feel */
    box-shadow: 0 3px 18px rgba(255, 157, 60, 0.22);
  }
  .ms-title {
    margin: 0;
    font-size: clamp(16px, 3.2vw, 34px);
    letter-spacing: clamp(3px, 0.8vw, 8px);
    color: #fff2e6;
    text-shadow:
      4px 4px 0 #0a0c14,
      -2px -2px 0 #0a0c14,
      0 0 10px rgba(255, 157, 60, 1),
      0 0 28px rgba(255, 157, 60, 0.7),
      0 0 60px rgba(255, 90, 77, 0.4);
  }
  .ms-subtitle {
    margin: clamp(4px, 0.6vh, 8px) 0 0;
    font-size: clamp(7px, 1.1vw, 9px);
    letter-spacing: 2px;
    color: #ff9d3c;
    animation: blink-press 1s steps(1) infinite;
  }
  @keyframes blink-press {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* ─── Character stages row ───────────────────────────── */
  .char-cards {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
    position: relative;
    z-index: 5;
  }

  /* ─── Individual character stage / card ─────────────── */
  .char-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1 1 0;
    min-width: 0;
    /* Allow standee to break OUT above the frame */
    overflow: visible;
    /* Clip only horizontal sides for cleanliness */
    clip-path: none;
    padding: clamp(8px, 1.5vh, 18px) clamp(10px, 1.5vw, 28px) clamp(10px, 1.8vh, 20px);
    box-sizing: border-box;
    border: 3px solid rgba(255, 157, 60, 0.55);
    box-shadow:
      inset 0 0 0 2px rgba(255, 90, 77, 0.12),
      0 0 24px rgba(255, 157, 60, 0.18),
      0 0 50px rgba(255, 90, 77, 0.08);
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease;
    animation: frame-pulse 2.4s ease-in-out infinite;
  }
  .char-card:nth-child(2) {
    animation-delay: 1.2s;
  }
  @keyframes frame-pulse {
    0%, 100% {
      box-shadow:
        inset 0 0 0 2px rgba(255, 90, 77, 0.12),
        0 0 24px rgba(255, 157, 60, 0.18),
        0 0 50px rgba(255, 90, 77, 0.08);
    }
    50% {
      box-shadow:
        inset 0 0 0 2px rgba(255, 90, 77, 0.28),
        0 0 40px rgba(255, 157, 60, 0.38),
        0 0 80px rgba(255, 90, 77, 0.18);
    }
  }

  /* Hover / focus: full neon activation */
  .char-card:hover,
  .char-card:focus-within {
    border-color: #ff9d3c;
    transform: scale(1.02);
    animation: frame-pulse-hot 0.6s ease-in-out infinite;
    z-index: 8;
  }
  @keyframes frame-pulse-hot {
    0%, 100% {
      box-shadow:
        inset 0 0 0 3px rgba(255, 90, 77, 0.5),
        0 0 32px rgba(255, 157, 60, 0.75),
        0 0 80px rgba(255, 90, 77, 0.5),
        0 0 140px rgba(255, 210, 63, 0.22);
    }
    50% {
      box-shadow:
        inset 0 0 0 3px rgba(255, 90, 77, 0.85),
        0 0 56px rgba(255, 157, 60, 1),
        0 0 110px rgba(255, 90, 77, 0.68),
        0 0 180px rgba(255, 210, 63, 0.38);
    }
  }

  /* Hover: brighten block + radial */
  .char-card:hover .char-block,
  .char-card:focus-within .char-block {
    filter: brightness(1.18) saturate(1.15);
  }
  .char-card:hover .spotlight-radial,
  .char-card:focus-within .spotlight-radial {
    opacity: 1;
  }
  .char-card:hover .ground-glow,
  .char-card:focus-within .ground-glow {
    opacity: 1;
    animation: ground-glow-pulse-hot 0.5s ease-in-out infinite;
  }
  /* START button lift on card hover */
  .char-card:hover .char-start,
  .char-card:focus-within .char-start {
    transform: translateY(-3px) scale(1.04);
    color: #fff2e6;
    background: rgba(255, 90, 40, 0.2);
    box-shadow:
      0 0 30px rgba(255, 157, 60, 0.85),
      0 0 60px rgba(255, 90, 77, 0.5),
      inset 0 0 14px rgba(255, 157, 60, 0.15);
    text-shadow: 1px 1px 0 #0a0c14, 0 0 10px rgba(255, 200, 60, 1);
    border-color: #ff9d3c;
  }

  /* ─── Big themed art block ───────────────────────────── */
  .char-block {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    /* Pixel-art texture intact */
    image-rendering: pixelated;
    /* Amber arcade frame inset double-line */
    box-shadow:
      inset 0 0 0 3px rgba(255, 157, 60, 0.85),
      inset 0 0 0 6px rgba(255, 157, 60, 0.22);
    /* Dark border sealing the art inside */
    border: 3px solid rgba(255, 157, 60, 0.7);
    overflow: hidden;
    transition: filter 0.2s ease;
    z-index: 0;
  }
  /* Dark gradient overlay on the bottom third for legibility */
  .char-block-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8, 6, 12, 0.0) 0%,
      rgba(8, 6, 12, 0.05) 45%,
      rgba(8, 6, 12, 0.62) 72%,
      rgba(8, 6, 12, 0.92) 100%
    );
  }

  /* ─── Radial spotlight behind upper body ─────────────── */
  .spotlight-radial {
    position: absolute;
    /* Center in upper 55% of card */
    top: 5%;
    left: 50%;
    transform: translateX(-50%);
    width: 75%;
    height: 58%;
    background: radial-gradient(
      ellipse 60% 70% at 50% 38%,
      rgba(255, 200, 120, 0.13) 0%,
      rgba(255, 160, 70, 0.07) 45%,
      transparent 100%
    );
    pointer-events: none;
    opacity: 0.75;
    transition: opacity 0.25s ease;
    z-index: 1;
  }

  /* ─── Character figure — breakout standee ───────────── */
  .char-figure {
    position: relative;
    /* Sit in the flow: push toward top so standee top can overflow */
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    z-index: 3;
    /* We need the image to peek above the card top,
       so use a negative top margin to "pull" the figure up */
    margin-top: -48px;
  }
  .char-fig-img {
    display: block;
    height: clamp(220px, 50vh, 520px);
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.88))
            drop-shadow(0 0 8px rgba(255, 157, 60, 0.35))
            drop-shadow(0 0 20px rgba(255, 90, 77, 0.2));
    position: relative;
    z-index: 2;
    animation: idle-bob 2.2s ease-in-out infinite;
  }
  /* Offset second character */
  .char-card:nth-child(2) .char-fig-img {
    animation-delay: -0.9s;
  }
  @keyframes idle-bob {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-6px); }
  }

  /* Ground glow at feet */
  .ground-glow {
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 64%;
    height: 30px;
    background: radial-gradient(
      ellipse at 50% 100%,
      rgba(255, 157, 60, 0.55) 0%,
      rgba(255, 90, 77, 0.22) 50%,
      transparent 100%
    );
    border-radius: 50%;
    pointer-events: none;
    opacity: 0.65;
    animation: ground-glow-pulse 2.2s ease-in-out infinite;
    z-index: 2;
  }
  .char-card:nth-child(2) .ground-glow {
    animation-delay: -0.9s;
  }
  @keyframes ground-glow-pulse {
    0%, 100% { opacity: 0.55; transform: translateX(-50%) scaleX(1); }
    50%       { opacity: 0.85; transform: translateX(-50%) scaleX(1.12); }
  }
  @keyframes ground-glow-pulse-hot {
    0%, 100% { opacity: 0.9; transform: translateX(-50%) scaleX(1.1); }
    50%       { opacity: 1;   transform: translateX(-50%) scaleX(1.28); }
  }

  /* ─── Angled name banner (arcade nameplate) ─────────── */
  .char-banner {
    width: 92%;
    text-align: center;
    padding: clamp(5px, 0.9vh, 10px) clamp(8px, 1vw, 14px);
    margin: clamp(4px, 0.6vh, 8px) 0;
    background: rgba(8, 5, 16, 0.84);
    border: 2px solid rgba(255, 157, 60, 0.78);
    /* Notched + slightly angled corners — arcade nameplate */
    clip-path: polygon(
      0 10px, 10px 0,
      calc(100% - 10px) 0, 100% 10px,
      100% calc(100% - 6px), calc(100% - 6px) 100%,
      6px 100%, 0 calc(100% - 10px)
    );
    position: relative;
    z-index: 4;
    box-shadow: 0 0 16px rgba(255, 157, 60, 0.35);
  }
  .char-name {
    font-size: clamp(14px, 2vw, 24px);
    letter-spacing: 3px;
    color: #fff2e6;
    text-shadow:
      2px 2px 0 #0a0c14,
      0 0 8px rgba(255, 157, 60, 0.85),
      0 0 22px rgba(255, 157, 60, 0.45);
  }
  .char-role {
    margin-top: 3px;
    font-size: clamp(7px, 0.95vw, 9px);
    letter-spacing: 1.5px;
    color: #c98f6a;
  }

  /* ─── Segmented arcade stat gauges ───────────────────── */
  .char-stats {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: clamp(4px, 0.7vh, 8px);
    position: relative;
    z-index: 4;
  }
  .stat-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .stat-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.8));
  }
  .stat-pips {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 3px;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  .pip {
    display: inline-block;
    width: clamp(8px, 1.4vw, 16px);
    height: clamp(8px, 1.3vh, 14px);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .pip--solid {
    background: linear-gradient(180deg, #ffda6b 0%, #ff8c1a 100%);
    box-shadow:
      0 0 4px rgba(255, 157, 60, 0.9),
      0 0 8px rgba(255, 157, 60, 0.5),
      inset 0 1px 0 rgba(255, 255, 180, 0.4);
    border: 1px solid rgba(255, 200, 60, 0.6);
  }
  .pip--growth {
    background: rgba(255, 130, 40, 0.18);
    border: 1px solid rgba(255, 157, 60, 0.45);
    box-shadow: 0 0 3px rgba(255, 157, 60, 0.2);
  }
  .pip--empty {
    background: rgba(10, 12, 20, 0.6);
    border: 1px solid rgba(80, 60, 40, 0.4);
  }
  .stat-val {
    flex-shrink: 0;
    font-size: clamp(7px, 0.9vw, 9px);
    letter-spacing: 0;
    color: #ffd7a8;
    text-align: right;
    min-width: 36px;
  }
  .stat-num {
    color: #ffd23f;
  }
  .stat-num--cap {
    color: #ff9d3c;
  }
  .arrow {
    color: #c98f6a;
    margin: 0 1px;
  }

  /* ─── START button ───────────────────────────────────── */
  .ms-btn {
    padding: clamp(10px, 1.5vh, 16px) clamp(12px, 1.5vw, 22px);
    font-family: inherit;
    font-size: clamp(9px, 1.1vw, 12px);
    letter-spacing: 2px;
    color: #ffe9d6;
    background: rgba(8, 12, 22, 0.88);
    border: 3px solid rgba(255, 157, 60, 0.8);
    border-radius: 0;
    clip-path: polygon(
      0 6px, 6px 0,
      calc(100% - 6px) 0, 100% 6px,
      100% calc(100% - 6px), calc(100% - 6px) 100%,
      6px 100%, 0 calc(100% - 6px)
    );
    box-shadow:
      0 0 14px rgba(255, 157, 60, 0.45),
      inset 0 0 12px rgba(255, 90, 77, 0.08);
    cursor: pointer;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
    position: relative;
    z-index: 5;
    width: 100%;
    margin-top: clamp(5px, 0.8vh, 10px);
    text-shadow: 1px 1px 0 #0a0c14, 0 0 6px rgba(255, 157, 60, 0.6);
  }
  .ms-btn:hover {
    transform: translateY(-3px) scale(1.04);
    color: #fff2e6;
    background: rgba(255, 90, 40, 0.18);
    box-shadow:
      0 0 30px rgba(255, 157, 60, 0.85),
      0 0 60px rgba(255, 90, 77, 0.5),
