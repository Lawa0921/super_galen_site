---
/**
 * /games — Dungeon Arcade 遊戲廳卡片牆
 * 對標 docs/.../mockups/ui/A-hall.jpg
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import ArcadeBgm from '@components/ArcadeBgm.astro';
import { defaultLang, type Language } from '@i18n/index';

const lang: Language = defaultLang;

const games = [
  { id: 'tetris', title: 'BATTLE TETRIS', href: '/games/tetris', active: true, art: '/assets/games/tetris/card-tetris.webp' },
  { id: 'bomber', title: 'DUNGEON BOMBER', href: '/games/bomber', active: true, art: '/assets/games/bomber/card-bomber.webp' },
  { id: 'witchrun', title: 'WITCH RUN', href: '/games/witchrun', active: true, art: '/assets/games/witchrun/card-witchrun.webp' },
  { id: 'defense', title: 'DUNGEON DEFENSE', href: '/games/defense', active: true, art: '/assets/games/defense/card-defense.webp' },
];
---

<BaseLayout title="Dungeon Arcade" description="SuperGalen's Dungeon 遊戲廳" lang={lang}>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" />

  <main class="arcade">
    <div class="arcade-boot" aria-hidden="true"></div>
    <a class="arcade-home" href="/">← HOME</a>
    <h1 class="arcade-title">DUNGEON ARCADE</h1>

    <div class="card-wall">
      {games.map((g) =>
        g.active && g.href ? (
          <a class="card card--active" href={g.href}>
            <img class="card-art-img" src={g.art} alt="" aria-hidden="true" loading="eager" />
            <span class="card-title">{g.title}</span>
            <span class="card-play">PLAY</span>
          </a>
        ) : (
          <div class="card card--locked" aria-disabled="true">
            <img class="card-art-img" src={g.art} alt="" aria-hidden="true" loading="lazy" />
            <span class="card-lock" aria-hidden="true"></span>
            <span class="card-title">{g.title}</span>
          </div>
        )
      )}
    </div>

    <a class="lb-link" href="/games/leaderboard"><i class="fas fa-trophy"></i> 排行榜 LEADERBOARD</a>
  </main>

  <ArcadeBgm track="/assets/games/bgm/arcade.mp3" />
</BaseLayout>

<style>
  .arcade {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 48px;
    padding: 40px 20px;
    overflow: auto;
    background:
      radial-gradient(ellipse at 50% 35%, rgba(54, 230, 255, 0.08), transparent 60%),
      linear-gradient(180deg, rgba(4, 6, 13, 0.82), rgba(4, 6, 13, 0.92)),
      url('/assets/games/tetris/bg-dungeon.webp') center / cover no-repeat;
    font-family: 'Press Start 2P', Consolas, monospace;
  }
  .arcade-home {
    position: absolute;
    top: 18px;
    left: 20px;
    font-size: 11px;
    letter-spacing: 1px;
    color: #6fa8d8;
    text-decoration: none;
    opacity: 0.8;
  }
  .arcade-home:hover { color: #36e6ff; opacity: 1; }
  .arcade-title {
    margin: 0;
    font-size: clamp(20px, 4vw, 40px);
    letter-spacing: 4px;
    color: #eafdff;
    text-shadow: 0 0 12px rgba(54, 230, 255, 0.9), 0 0 32px rgba(54, 230, 255, 0.5);
  }
  .card-wall {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    justify-content: center;
    max-width: 980px;
  }
  .card {
    position: relative;
    width: 220px;
    height: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    padding-bottom: 18px;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    background: rgba(8, 12, 22, 0.72);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .card-title { font-size: 13px; letter-spacing: 2px; position: relative; }
  .card--active {
    border: 2px solid rgba(54, 230, 255, 0.85);
    box-shadow: 0 0 16px rgba(54, 230, 255, 0.45), inset 0 0 18px rgba(54, 230, 255, 0.12);
    color: #eafdff;
    cursor: pointer;
  }
  .card--active:hover {
    transform: translateY(-6px) scale(1.03);
    box-shadow: 0 0 28px rgba(54, 230, 255, 0.8), inset 0 0 24px rgba(54, 230, 255, 0.2);
  }
  /* 卡片主視覺：滿版鋪底，底部加暗色漸層讓標題/PLAY 清楚 */
  .card-art-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.18s ease;
  }
  .card--active::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgba(4, 6, 13, 0.55) 70%, rgba(4, 6, 13, 0.92) 100%);
  }
  .card--active:hover .card-art-img { transform: scale(1.06); }
  .card-play { font-size: 10px; letter-spacing: 2px; color: #36e6ff; position: relative; }
  .card-play::before {
    content: '';
    display: inline-block;
    width: 1.4em;
    height: 1.4em;
    margin-right: 5px;
    vertical-align: -0.3em;
    background: center / contain no-repeat url('/assets/games/tetris/icons/play.webp');
  }
  .card--locked {
    justify-content: center;
    gap: 18px;
    padding-bottom: 0;
    border: 2px solid rgba(90, 114, 153, 0.4);
    color: #8aa0c4;
    cursor: not-allowed;
  }
  .card--locked .card-art-img { opacity: 0.45; filter: grayscale(0.35); }
  .card--locked::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(4, 6, 13, 0.45);
  }
  .card-lock {
    width: 34px;
    height: 34px;
    opacity: 0.85;
    position: relative;
    background: center / contain no-repeat url('/assets/games/tetris/icons/lock.webp');
  }

  .lb-link {
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: #ffd23f;
    text-decoration: none;
    padding: 12px 22px;
    border: 1px solid rgba(255, 210, 63, 0.55);
    border-radius: 8px;
    box-shadow: 0 0 12px rgba(255, 210, 63, 0.25);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .lb-link:hover { transform: translateY(-2px); box-shadow: 0 0 22px rgba(255, 210, 63, 0.6); }

  @media (max-width: 560px) {
    .card { width: 70vw; height: 200px; }
  }

  /* ---- 進場動畫（開機式） ---- */
  .arcade-boot {
    position: absolute;
    inset: 0;
    z-index: 50;
    pointer-events: none;
    background:
      repeating-linear-gradient(0deg, rgba(54, 230, 255, 0.14) 0 2px, transparent 2px 4px),
      radial-gradient(ellipse at center, rgba(54, 230, 255, 0.28), rgba(4, 6, 13, 0.98));
    transform-origin: center;
    animation: arcadeBootOut 0.95s ease forwards;
  }
  @keyframes arcadeBootOut {
    0% { opacity: 1; transform: scaleY(1); }
    40% { opacity: 1; transform: scaleY(1); }
    100% { opacity: 0; transform: scaleY(0); }
  }

  .arcade-title {
    animation: arcadeTitleIn 0.7s 0.28s both cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes arcadeTitleIn {
    0% { opacity: 0; transform: translateY(-22px) scale(0.9); filter: brightness(2.2) blur(5px); letter-spacing: 16px; }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: none; letter-spacing: 4px; }
  }

  .card { animation: arcadeCardIn 0.5s both ease; }
  .card-wall .card:nth-child(1) { animation-delay: 0.5s; }
  .card-wall .card:nth-child(2) { animation-delay: 0.64s; }
  .card-wall .card:nth-child(3) { animation-delay: 0.78s; }
  @keyframes arcadeCardIn {
    0% { opacity: 0; transform: translateY(32px) scale(0.92); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .arcade-boot { display: none; }
    .arcade-title,
    .card { animation: none; }
  }
</style>
