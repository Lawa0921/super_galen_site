---
/**
 * /games/leaderboard — Dungeon Arcade 線上對戰排行榜
 * 從 /api/leaderboard 取資料、霓虹地城風渲染。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import { defaultLang, type Language } from '@i18n/index';

const lang: Language = defaultLang;
---

<BaseLayout title="Dungeon Arcade — 排行榜" description="線上對戰 ELO 排行榜" lang={lang}>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" />

  <main class="lb">
    <a class="lb-home" href="/games">← ARCADE</a>
    <h1 class="lb-title">LEADERBOARD</h1>
    <div class="lb-tabs" id="lb-tabs" role="tablist" aria-label="Leaderboard game">
      <button class="lb-tab is-active" id="lb-tab-tetris" type="button" role="tab" aria-selected="true" data-game="tetris">TETRIS</button>
      <button class="lb-tab" id="lb-tab-bomber" type="button" role="tab" aria-selected="false" data-game="bomber">BOMBER</button>
    </div>
    <div class="lb-board" id="lb-board">
      <p class="lb-empty" id="lb-status">載入中…</p>
    </div>
  </main>
</BaseLayout>

<style>
  .lb {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    padding: 56px 16px 32px;
    overflow: auto;
    background:
      linear-gradient(180deg, rgba(4, 6, 13, 0.86), rgba(4, 6, 13, 0.94)),
      url('/assets/games/tetris/bg-dungeon.webp') center / cover no-repeat fixed;
    font-family: 'Press Start 2P', Consolas, monospace;
    color: #cfe8ff;
  }
  .lb-home {
    position: absolute;
    top: 18px;
    left: 20px;
    font-size: 11px;
    letter-spacing: 1px;
    color: #6fa8d8;
    text-decoration: none;
    opacity: 0.8;
  }
  .lb-home:hover { color: #36e6ff; opacity: 1; }
  .lb-title {
    margin: 0;
    font-size: clamp(18px, 3.5vw, 34px);
    letter-spacing: 4px;
    color: #eafdff;
    text-shadow: 0 0 12px rgba(54, 230, 255, 0.9), 0 0 30px rgba(54, 230, 255, 0.5);
  }
  .lb-tabs {
    display: flex;
    gap: 10px;
    width: min(760px, 94vw);
    justify-content: center;
  }
  .lb-tab {
    flex: 0 0 auto;
    padding: 10px 22px;
    font-family: inherit;
    font-size: 11px;
    letter-spacing: 2px;
    color: #6fa8d8;
    background: rgba(8, 12, 22, 0.72);
    border: 1px solid rgba(54, 230, 255, 0.22);
    border-radius: 8px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, box-shadow 0.15s;
  }
  .lb-tab:hover { color: #36e6ff; }
  .lb-tab.is-active {
    color: #eafdff;
    border-color: rgba(54, 230, 255, 0.6);
    box-shadow: 0 0 14px rgba(54, 230, 255, 0.25);
  }
  .lb-board {
    width: min(760px, 94vw);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .lb-empty { text-align: center; font-size: 11px; line-height: 1.8; color: #7f93b8; }
  .lb-row {
    display: grid;
    grid-template-columns: 44px 1fr 96px 70px 70px;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    font-size: 11px;
    background: rgba(8, 12, 22, 0.72);
    border: 1px solid rgba(54, 230, 255, 0.22);
    border-radius: 8px;
  }
  .lb-row.lb-head {
    background: transparent;
    border-color: transparent;
    color: #7f93b8;
    font-size: 9px;
    letter-spacing: 1px;
  }
  .lb-row.lb-top { border-color: rgba(255, 210, 63, 0.6); box-shadow: 0 0 14px rgba(255, 210, 63, 0.2); }
  .lb-rank { color: #ffd23f; }
  .lb-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .lb-tier { font-size: 9px; }
  .lb-rating { color: #36e6ff; text-align: right; }
  .lb-wl { color: #9fb4d8; text-align: right; font-size: 9px; }
</style>

<script>
  type Row = { id: string; rating: number; tier: string; wins: number; losses: number; name?: string };

  type Game = 'tetris' | 'bomber';

  const board = document.getElementById('lb-board');
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.lb-tab'));
  const short = (id: string) => (id.startsWith('0x') && id.length > 12 ? `${id.slice(0, 6)}…${id.slice(-4)}` : id);
  const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));

  let active: Game = 'tetris';
  let reqToken = 0; // 防止慢回應覆蓋後選的分頁

  async function load(game: Game): Promise<void> {
    if (!board) return;
    const token = ++reqToken;
    board.innerHTML = '<p class="lb-empty">載入中…</p>';
    try {
      const res = await fetch(`/api/leaderboard?n=50&game=${game}`);
      const { rows } = (await res.json()) as { rows: Row[] };
      if (token !== reqToken) return; // 已切換分頁，丟棄過期回應
      if (!rows || rows.length === 0) {
        board.innerHTML = '<p class="lb-empty">尚無對戰紀錄<br/>到遊戲室開一場線上對戰來上榜！</p>';
        return;
      }
      const head = '<div class="lb-row lb-head"><span>#</span><span>PLAYER</span><span>TIER</span><span>ELO</span><span>W/L</span></div>';
      const body = rows
        .map((r, i) => {
          const cls = i === 0 ? 'lb-row lb-top' : 'lb-row';
          const name = r.name ? esc(r.name) : short(r.id);
          return `<div class="${cls}"><span class="lb-rank">${i + 1}</span><span class="lb-name">${name}</span><span class="lb-tier">${esc(r.tier)}</span><span class="lb-rating">${r.rating}</span><span class="lb-wl">${r.wins}/${r.losses}</span></div>`;
        })
        .join('');
      board.innerHTML = head + body;
    } catch {
      if (token !== reqToken) return;
      board.innerHTML = '<p class="lb-empty">排行榜載入失敗</p>';
    }
  }

  function selectGame(game: Game): void {
    if (game === active) return;
    active = game;
    for (const tab of tabs) {
      const on = tab.dataset.game === game;
      tab.classList.toggle('is-active', on);
      tab.setAttribute('aria-selected', String(on));
    }
    void load(game);
  }

  for (const tab of tabs) {
    tab.addEventListener('click', () => selectGame((tab.dataset.game as Game) ?? 'tetris'));
  }

  void load(active);
</script>
