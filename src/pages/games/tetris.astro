<script>
  import { startTetris } from '@scripts/games/tetris/render/main';
  import { startAi } from '@scripts/games/tetris/render/aiMain';
  import { SKILLS, type SkillId, type PerkChoice, type PerkId } from '@scripts/games/tetris/engine/run';
  import { SKIN_CATALOG, getSelectedSkin, setSelectedSkin, isUnlocked, resolveSkin } from '@scripts/games/tetris/render/skins';
  import { HANDLING_DEFAULT, loadHandling, saveHandling, type Handling } from '@scripts/games/tetris/input/handling';
  import { hostGame, joinGame, connectWallet, type NetStatus, type Identity } from '@scripts/games/tetris/net/netMain';
  import { hostFfaGame, joinFfaGame, type FfaNetStatus, type FfaIdentity } from '@scripts/games/tetris/net/ffaNetMain';
  import { startQueue, type MatchedInfo, type QueueHandle } from '@scripts/games/tetris/net/queueClient';
  import { DEFAULT_RATING } from '@scripts/games/tetris/net/elo';

  type Diff = 'easy' | 'normal' | 'hard' | 'insane';
  const SOLO_HINT = 'MOVE ←→ · ROTATE ↑/Z · DROP SPACE · HOLD SHIFT · ESC PAUSE · MUTE M';
  const ONLINE_HINT = 'ONLINE · MOVE ←→ · ROTATE ↑/Z · DROP SPACE · HOLD SHIFT · ESC MENU · MUTE M';

  const params = new URLSearchParams(location.search);
  const canvas = document.getElementById('tetris-canvas') as HTMLCanvasElement | null;
  const hint = document.getElementById('tetris-hint');
  const mainMenu = document.getElementById('main-menu');
  const modeSelect = document.getElementById('mode-select');
  const onlinePanel = document.getElementById('online-panel');
  const statusEl = document.getElementById('online-status');

  // 玩家人數選擇（2–8，預設 2）：N=2 走既有 1v1 路徑（零回歸），N≥3 走 FFA 星狀。
  let playerCount = 2;
  const pcButtons = Array.from(document.querySelectorAll<HTMLElement>('.pc-btn'));
  pcButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const n = Number(btn.dataset.count);
      if (!Number.isFinite(n) || n < 2 || n > 8) return;
      playerCount = n;
      pcButtons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    });
  });
  // ---- HANDLING 手感設定（DAS/ARR/SDF 滑桿；改動即存，下一局開局讀取）----
  const handlingOpen = document.getElementById('handling-open');
  const handlingPanel = document.getElementById('handling-panel');
  const handlingSliders = Array.from(document.querySelectorAll<HTMLInputElement>('.hp-slider'));

  function renderHandling(h: Handling): void {
    handlingSliders.forEach((s) => {
      const key = s.dataset.handling as keyof Handling | undefined;
      if (!key) return;
      s.value = String(h[key]);
      const val = document.getElementById(`handling-${key}-val`);
      if (val) val.textContent = `${h[key]}ms`;
    });
  }

  function readHandlingFromSliders(): Handling {
    const h: Handling = { ...HANDLING_DEFAULT };
    handlingSliders.forEach((s) => {
      const key = s.dataset.handling as keyof Handling | undefined;
      if (key) h[key] = Number(s.value);
    });
    return h;
  }

  handlingOpen?.addEventListener('click', () => {
    if (!handlingPanel) return;
    const open = handlingPanel.hidden;
    if (open) renderHandling(loadHandling()); // 開啟時同步現值
    handlingPanel.hidden = !open;
    handlingOpen.setAttribute('aria-expanded', open ? 'true' : 'false');
    blip(open ? 560 : 300, 0.06);
  });
  handlingSliders.forEach((s) => {
    s.addEventListener('input', () => {
      const h = readHandlingFromSliders();
      renderHandling(h);
      saveHandling(h); // 改動即存，下一局生效
    });
  });
  document.getElementById('handling-reset')?.addEventListener('click', () => {
    renderHandling(HANDLING_DEFAULT);
    saveHandling({ ...HANDLING_DEFAULT });
    blip(640, 0.06);
  });
  document.getElementById('handling-done')?.addEventListener('click', () => {
    if (handlingPanel) handlingPanel.hidden = true;
    handlingOpen?.setAttribute('aria-expanded', 'false');
    blip(680, 0.06);
  });

  const touchNotice = document.getElementById('touch-notice');
  // 觸控裝置（多半無實體鍵盤）→ 收掉遊玩入口、明講請用電腦；排行榜/檔案分頁仍可用
  const isTouch = matchMedia('(pointer: coarse)').matches;
  function showTouchNotice(): void {
    if (modeSelect) modeSelect.hidden = true;
    if (onlinePanel) onlinePanel.hidden = true;
    if (touchNotice) touchNotice.hidden = false;
  }
  let started = false;
  let gameHandle: { pause?(): void; resume?(): void; restart?(): void; leaveMatch?(): void } | null = null;
  let gameRunning = false;
  let pausable = false;
  let menuOpen = false;
  let resultOpen = false;
  let perkOpen = false; // 三選一開啟中（ESC 互斥：perk 開啟時不開暫停選單）
  let isQueueMatch = false; // 快速配對局：lobby 不顯示 START（autoStart）、文案改「配對成功」
  const pauseMenu = document.getElementById('pause-menu');
  const pauseTitle = document.getElementById('pause-title');
  const pauseHint = document.getElementById('pause-hint');
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  const setHint = (t: string) => { if (hint) { hint.textContent = t; hint.hidden = false; } };

  // ---- 合成音效（Web Audio，首次手勢時建立）----
  let actx: AudioContext | null = null;
  function blip(freq: number, dur = 0.08, type: OscillatorType = 'square'): void {
    try {
      const Ctx = window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext;
      actx = actx ?? new Ctx();
      if (actx.state === 'suspended') void actx.resume();
      const o = actx.createOscillator();
      const g = actx.createGain();
      o.type = type;
      o.frequency.value = freq;
      o.connect(g).connect(actx.destination);
      const t = actx.currentTime;
      g.gain.setValueAtTime(0.05, t);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      o.start(t);
      o.stop(t + dur);
    } catch { /* 音效非必要 */ }
  }

  // ---- ESC 暫停選單（solo/AI 暫停模擬；online 鎖步不可暫停 → 改「離開對戰？」確認、淡背景）----
  function openPauseMenu(): void {
    if (!gameRunning || menuOpen || resultOpen) return;
    menuOpen = true;
    if (pausable) gameHandle?.pause?.();
    if (pauseTitle) pauseTitle.textContent = pausable ? 'PAUSED' : '離開對戰？';
    if (pauseHint) pauseHint.hidden = pausable; // 線上才顯示判敗提示
    if (pauseMenu) { pauseMenu.classList.toggle('is-online', !pausable); pauseMenu.hidden = false; }
    blip(300, 0.1);
  }
  function closePauseMenu(): void {
    if (!menuOpen) return;
    menuOpen = false;
    if (pausable) gameHandle?.resume?.();
    if (pauseMenu) pauseMenu.hidden = true;
    blip(560, 0.07);
  }
  window.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape' || !gameRunning || resultOpen || perkOpen) return;
    e.preventDefault();
    if (menuOpen) closePauseMenu();
    else openPauseMenu();
  });
  document.getElementById('pause-resume')?.addEventListener('click', closePauseMenu);
  document.getElementById('pause-quit')?.addEventListener('click', () => {
    // 線上 FFA：離開前先送 ffa-leave（host 立即判敗、其餘玩家續行）；其他模式為 no-op。
    gameHandle?.leaveMatch?.();
    location.href = '/games/tetris';
  });

  // ---- 結算覆蓋層（SOLO game over / vs-AI 勝負）----
  const resultMenu = document.getElementById('result-menu');
  const resultTitle = document.getElementById('result-title');
  function showResult(title: string): void {
    resultOpen = true;
    if (resultTitle) resultTitle.textContent = title;
    if (resultMenu) resultMenu.hidden = false;
    blip(440, 0.12, 'sawtooth');
  }
  document.getElementById('result-again')?.addEventListener('click', () => {
    resultOpen = false;
    if (resultMenu) resultMenu.hidden = true;
    gameHandle?.restart?.();
    blip(680, 0.07);
  });
  document.getElementById('result-quit')?.addEventListener('click', () => { location.href = '/games/tetris'; });

  // ---- SOLO 升級三選一（main.ts 經 onPerkChoices 回呼丟卡片，DOM 全在這層）----
  const perkMenu = document.getElementById('perk-menu');
  const perkCards = Array.from(document.querySelectorAll<HTMLButtonElement>('.perk-card'));
  let perkChoices: PerkChoice[] = [];
  let perkPick: ((id: PerkId) => void) | null = null;

  function showPerkMenu(choices: PerkChoice[], pick: (id: PerkId) => void): void {
    perkChoices = choices;
    perkPick = pick;
    perkCards.forEach((card, i) => {
      const c = choices[i];
      card.hidden = !c; // 池不足 3 張時隱藏空槽
      if (!c) return;
      card.dataset.perk = c.id;
      const name = card.querySelector('.perk-name');
      const desc = card.querySelector('.perk-desc');
      if (name) name.textContent = c.name;
      if (desc) desc.textContent = c.desc;
    });
    perkOpen = true;
    if (perkMenu) perkMenu.hidden = false;
    blip(620, 0.09);
  }

  function pickPerkSlot(i: number): void {
    if (!perkOpen) return;
    const c = perkChoices[i];
    if (!c) return;
    perkOpen = false;
    if (perkMenu) perkMenu.hidden = true;
    const pick = perkPick;
    perkPick = null;
    pick?.(c.id); // main.ts：pickPerk → survivor 檢查 → resume
    blip(760, 0.07);
  }

  perkCards.forEach((card, i) => card.addEventListener('click', () => pickPerkSlot(i)));
  window.addEventListener('keydown', (e) => {
    if (!perkOpen) return;
    const n = Number(e.key);
    if (!Number.isInteger(n) || n < 1 || n > 3) return;
    e.preventDefault();
    pickPerkSlot(n - 1);
  });

  // ---- 線上 lobby（建房等待對手）----
  const lobby = document.getElementById('online-lobby');
  const lobbyCode = document.getElementById('lobby-code');
  const lobbyWait = document.getElementById('lobby-wait');
  const lobbyCount = document.getElementById('lobby-count');
  const lobbyJoined = document.getElementById('lobby-joined');
  const lobbyTarget = document.getElementById('lobby-target');
  const lobbyStart = document.getElementById('lobby-start') as HTMLButtonElement | null;
  function showLobby(phase: string, room?: string): void {
    if (modeSelect) modeSelect.hidden = true;
    if (onlinePanel) onlinePanel.hidden = true;
    if (lobby) lobby.hidden = false;
    if (room && lobbyCode) lobbyCode.textContent = room;
    if (lobbyWait) {
      // 隊列局：玩家沒交換過房號，統一顯示配對成功（房號僅供 debug 觀察）
      lobbyWait.textContent = isQueueMatch
        ? '配對成功，連線中…'
        : phase === 'connecting' ? '連線中…' : phase === 'creating' ? '建立房間中…' : '等待對手加入…';
      lobbyWait.classList.add('pending');
    }
  }
  document.getElementById('lobby-copy')?.addEventListener('click', () => {
    const code = lobbyCode?.textContent ?? '';
    void navigator.clipboard?.writeText(code).then(() => {
      const btn = document.getElementById('lobby-copy');
      if (btn) { btn.textContent = '已複製'; setTimeout(() => { btn.textContent = '複製'; }, 1500); }
    }).catch(() => {});
    blip(700, 0.05);
  });
  document.getElementById('lobby-cancel')?.addEventListener('click', () => { location.href = '/games/tetris'; });

  function startSolo(skill: SkillId | null = null): void {
    if (isTouch) { showTouchNotice(); return; }
    if (started || !canvas) return;
    started = true;
    mainMenu?.remove();
    setHint(skill ? `${SOLO_HINT} · SKILL V` : SOLO_HINT);
    // 皮膚 key 與 PROFILE 皮膚櫃一致：已連錢包用 addr key，否則 guest key
    startTetris(canvas, {
      onEnd: () => showResult('GAME OVER'),
      skinId: getSelectedSkin(wallet?.address),
      skill,
      onPerkChoices: showPerkMenu, // SOLO roguelite 升級三選一
    })
      .then((h) => { gameHandle = h; gameRunning = true; pausable = true; })
      .catch((err: unknown) => console.error('[tetris] failed to start', err));
  }

  function startAiMode(diffRaw?: string | null, skill: SkillId | null = null): void {
    if (isTouch) { showTouchNotice(); return; }
    if (started || !canvas) return;
    started = true;
    mainMenu?.remove();
    const diff = (['easy', 'normal', 'hard', 'insane'].includes(diffRaw ?? '') ? diffRaw : 'normal') as Diff;
    setHint(`vs AI [${diff.toUpperCase()}] · MOVE ←→ · ROTATE ↑/Z · DROP SPACE · HOLD SHIFT${skill ? ' · SKILL V' : ''} · ESC PAUSE · M MUTE`);
    startAi(canvas, diff, { onEnd: (w) => showResult(w === 'A' ? 'YOU WIN' : 'AI WINS'), skinId: getSelectedSkin(wallet?.address), skill })
      .then((h) => { gameHandle = h; gameRunning = true; pausable = true; })
      .catch((err: unknown) => console.error('[tetris] failed to start', err));
  }

  // ---- 開局技能選擇步（UI 流程限定；深連結 ?mode= 直接開局以維持既有合約）----
  const skillSelect = document.getElementById('skill-select');
  const skillCards = Array.from(document.querySelectorAll<HTMLButtonElement>('.ss-card'));
  let pendingMode: 'solo' | 'ai' = 'solo';
  let pendingDiff: string | null = null;
  let skillSelectOpen = false;

  function showSkillSelect(mode: 'solo' | 'ai', diff?: string | null): void {
    if (isTouch) { showTouchNotice(); return; }
    if (started) return;
    pendingMode = mode;
    pendingDiff = diff ?? null;
    if (modeSelect) modeSelect.hidden = true;
    let n = 0; // shield 僅 vs-AI；數字快選鍵依可見順序重排
    skillCards.forEach((card) => {
      const show = mode === 'ai' || card.dataset.aionly !== 'true';
      card.hidden = !show;
      if (show) {
        n += 1;
        const key = card.querySelector('.ss-key');
        if (key) key.textContent = String(n);
      }
    });
    if (skillSelect) skillSelect.hidden = false;
    skillSelectOpen = true;
    blip(560, 0.06);
  }

  function pickSkill(raw: string): void {
    if (!skillSelectOpen || started) return;
    skillSelectOpen = false;
    const skill = raw && raw in SKILLS ? (raw as SkillId) : null;
    if (pendingMode === 'solo') startSolo(skill);
    else startAiMode(pendingDiff, skill);
    blip(680, 0.07);
  }

  skillCards.forEach((card) => {
    card.addEventListener('click', () => pickSkill(card.dataset.skill ?? ''));
  });
  window.addEventListener('keydown', (e) => {
    if (!skillSelectOpen) return;
    const n = Number(e.key);
    if (!Number.isInteger(n) || n < 1 || n > 5) return;
    const card = skillCards.filter((c) => !c.hidden)[n - 1];
    if (!card) return;
    e.preventDefault();
    pickSkill(card.dataset.skill ?? '');
  });

  function showOnlinePanel(): void {
    if (isTouch) { showTouchNotice(); return; }
    if (modeSelect) modeSelect.hidden = true;
    if (onlinePanel) onlinePanel.hidden = false;
  }

  function onStatus(s: NetStatus): void {
    if (s.phase === 'creating' || s.phase === 'waiting' || s.phase === 'connecting') {
      showLobby(s.phase, s.room);
    } else if (s.phase === 'connected') {
      mainMenu?.remove();
      setHint(ONLINE_HINT);
      gameRunning = true;
      pausable = false; // 線上對戰為 P2P 鎖步，不可暫停
    } else if (s.phase === 'error') {
      started = false; // 允許重試
      if (lobbyWait) {
        lobbyWait.textContent = `連線失敗：${s.message ?? ''}（按取消重試）`;
        lobbyWait.classList.remove('pending');
      }
    }
  }

  let wallet: { address: string; signMessage: (m: string) => Promise<string> } | null = null;

  function buildIdentity(): Identity {
    if (wallet) return { id: wallet.address, ranked: true, signMessage: wallet.signMessage };
    const nameEl = document.getElementById('online-name') as HTMLInputElement | null;
    const name = (nameEl?.value ?? '').trim();
    return { id: name || `Guest-${Math.floor(Math.random() * 9000 + 1000)}`, ranked: false };
  }

  async function onConnectWallet(): Promise<void> {
    try {
      wallet = await connectWallet();
      if (wallet) {
        const label = `${wallet.address.slice(0, 6)}…${wallet.address.slice(-4)}`;
        const onlineBtn = document.getElementById('online-wallet');
        if (onlineBtn) { onlineBtn.textContent = `${label}（排名賽）`; onlineBtn.classList.add('connected'); }
        const pfBtn = document.getElementById('profile-wallet');
        if (pfBtn) { pfBtn.textContent = label; pfBtn.classList.add('connected'); }
        void loadProfile(wallet.address);
      } else if (statusEl) {
        statusEl.textContent = '找不到錢包，將以暱稱進行（不計排名）';
      }
    } catch {
      if (statusEl) statusEl.textContent = '錢包連接取消';
    }
  }

  // FFA 身分（與 1v1 Identity 形狀相容）。
  function buildFfaIdentity(): FfaIdentity {
    const id = buildIdentity();
    return { id: id.id, ranked: id.ranked, signMessage: id.signMessage };
  }

  // host 端「開始」訊號：lobby START 按鈕 resolve 這個 promise。
  let resolveStart: (() => void) | null = null;
  function makeStartSignal(): Promise<void> {
    return new Promise<void>((res) => { resolveStart = res; });
  }

  // FFA 狀態 → lobby（host 顯示人數＋START，guest 顯示等待房主）。
  function onFfaStatus(s: FfaNetStatus, isHost: boolean): void {
    if (s.phase === 'creating' || s.phase === 'waiting') {
      showLobby('creating', s.room);
    } else if (s.phase === 'lobby') {
      showLobby('waiting', s.room);
      if (isHost) {
        const joined = (s.connected ?? 0) + 1; // host 自己 +1
        if (lobbyCount) lobbyCount.hidden = false;
        if (lobbyJoined) lobbyJoined.textContent = String(joined);
        if (lobbyTarget) lobbyTarget.textContent = String(playerCount);
        if (isQueueMatch) {
          // 隊列局：人到齊自動開始（hostFfaGame autoStart），不顯示 START 按鈕
          if (lobbyWait) lobbyWait.textContent = '配對成功，連線中…';
          if (lobbyStart) lobbyStart.hidden = true;
        } else {
          if (lobbyWait) lobbyWait.textContent = joined >= playerCount ? '人數已滿，可開始' : '等待玩家加入…';
          if (lobbyStart) {
            lobbyStart.hidden = false;
            lobbyStart.disabled = joined < 2; // 至少 2 人可開
          }
        }
      } else if (lobbyWait) {
        lobbyWait.textContent = isQueueMatch ? '配對成功，連線中…' : '已連線 · 等待房主開始…';
      }
    } else if (s.phase === 'connecting') {
      showLobby('connecting', s.room);
    } else if (s.phase === 'connected') {
      mainMenu?.remove();
      setHint(ONLINE_HINT);
      gameRunning = true;
      pausable = false;
    } else if (s.phase === 'error') {
      started = false;
      if (lobbyWait) {
        lobbyWait.textContent = `連線失敗：${s.message ?? ''}（按取消重試）`;
        lobbyWait.classList.remove('pending');
      }
    }
  }

  function beginHost(): void {
    if (started || !canvas) return;
    started = true;
    if (playerCount === 2) {
      hostGame(canvas, buildIdentity(), onStatus).catch((err: unknown) => onStatus({ phase: 'error', message: String(err) }));
      return;
    }
    // N≥3：FFA。maxGuests = playerCount - 1；START 按鈕觸發開局。
    const startSignal = makeStartSignal();
    hostFfaGame({
      canvas,
      identity: buildFfaIdentity(),
      maxGuests: playerCount - 1,
      waitStart: () => startSignal,
      onStatus: (s) => onFfaStatus(s, true),
      onHandle: (h) => { gameHandle = h; },
    }).catch((err: unknown) => onFfaStatus({ phase: 'error', message: String(err) }, true));
  }
  function beginJoin(): void {
    const input = document.getElementById('online-room') as HTMLInputElement | null;
    const room = (input?.value ?? '').trim().toUpperCase();
    if (!room) { if (statusEl) statusEl.textContent = '請輸入房號'; return; }
    if (started || !canvas) return;
    started = true;
    if (playerCount === 2) {
      joinGame(canvas, room, buildIdentity(), onStatus).catch((err: unknown) => onStatus({ phase: 'error', message: String(err) }));
      return;
    }
    // N≥3：FFA guest。
    joinFfaGame({
      canvas,
      room,
      identity: buildFfaIdentity(),
      maxGuests: playerCount - 1,
      onStatus: (s) => onFfaStatus(s, false),
      onHandle: (h) => { gameHandle = h; },
    }).catch((err: unknown) => onFfaStatus({ phase: 'error', message: String(err) }, false));
  }
  // ---- 快速配對（QUICK MATCH）：進隊列 → 撮合 → 自動接 host/join ----
  const queuePanel = document.getElementById('queue-panel');
  const queueStatus = document.getElementById('queue-status');
  const queueSeconds = document.getElementById('queue-seconds');
  const queueAiOffer = document.getElementById('queue-ai-offer');
  // 60 秒空池 AI 提示閾值：e2e 可用 ?queueAiMs= 或 window.__tetrisQueueAiMs 注入縮短
  const queueAiOfferMs =
    Number(params.get('queueAiMs')) ||
    (window as unknown as { __tetrisQueueAiMs?: number }).__tetrisQueueAiMs ||
    60_000;
  let queueHandle: QueueHandle | null = null;
  let queueTicker: ReturnType<typeof setInterval> | null = null;

  /** 隊列識別：暱稱欄位有值用之，否則 Player-xxxx（同時作為對局身分 id）。 */
  function queueIdentityId(): string {
    const nameEl = document.getElementById('online-name') as HTMLInputElement | null;
    const name = (nameEl?.value ?? '').trim();
    return name || `Player-${Math.floor(Math.random() * 9000 + 1000)}`;
  }

  function stopQueueUi(): void {
    if (queueTicker !== null) { clearInterval(queueTicker); queueTicker = null; }
    if (queuePanel) queuePanel.hidden = true;
  }

  function beginQuickMatch(): void {
    if (isTouch) { showTouchNotice(); return; }
    if (started || queueHandle) return;
    const qid = queueIdentityId();
    if (modeSelect) modeSelect.hidden = true;
    if (onlinePanel) onlinePanel.hidden = true;
    if (queuePanel) queuePanel.hidden = false;
    if (queueAiOffer) queueAiOffer.hidden = true;
    if (queueStatus) queueStatus.textContent = '正在尋找玩家…';
    if (queueSeconds) queueSeconds.textContent = '0';
    const t0 = Date.now();
    queueTicker = setInterval(() => {
      const elapsed = Date.now() - t0;
      if (queueSeconds) queueSeconds.textContent = String(Math.floor(elapsed / 1000));
      if (elapsed >= queueAiOfferMs && queueAiOffer) queueAiOffer.hidden = false;
    }, 250);
    queueHandle = startQueue({
      id: qid,
      name: qid,
      rating: DEFAULT_RATING,
      onUpdate: () => { /* 等待秒數以本地 ticker 顯示（較平滑） */ },
      onMatched: (info) => { queueHandle = null; onQueueMatched(qid, info); },
      onError: () => {
        queueHandle = null;
        if (queueStatus) queueStatus.textContent = '配對服務連線失敗，請按取消返回再試';
      },
    });
    blip(620, 0.07);
  }

  function onQueueMatched(qid: string, info: MatchedInfo): void {
    stopQueueUi();
    if (started || !canvas) return;
    started = true;
    isQueueMatch = true;
    playerCount = info.count; // lobby「已加入 x / y 人」以實際成局人數為準
    const identity: Identity = { id: qid, ranked: false }; // 隊列局不計排名
    if (info.mode === '1v1') {
      if (info.role === 'host') {
        hostGame(canvas, identity, onStatus, { room: info.room })
          .catch((err: unknown) => onStatus({ phase: 'error', message: String(err) }));
      } else {
        joinGame(canvas, info.room, identity, onStatus)
          .catch((err: unknown) => onStatus({ phase: 'error', message: String(err) }));
      }
      return;
    }
    // FFA：host autoStart（人到齊自動開局）；guest 依 roster 序位固定槽位（免並發 claim race）
    const maxGuests = info.count - 1;
    if (info.role === 'host') {
      hostFfaGame({
        canvas,
        identity,
        maxGuests,
        autoStart: true,
        room: info.room,
        onStatus: (s) => onFfaStatus(s, true),
        onHandle: (h) => { gameHandle = h; },
      }).catch((err: unknown) => onFfaStatus({ phase: 'error', message: String(err) }, true));
    } else {
      const rosterIdx = info.players.findIndex((p) => p.id === qid); // host=0 → guest 槽位 = idx-1
      joinFfaGame({
        canvas,
        room: info.room,
        identity,
        maxGuests,
        fixedSlot: rosterIdx > 0 ? rosterIdx - 1 : undefined,
        onStatus: (s) => onFfaStatus(s, false),
        onHandle: (h) => { gameHandle = h; },
      }).catch((err: unknown) => onFfaStatus({ phase: 'error', message: String(err) }, false));
    }
  }

  document.getElementById('quick-match')?.addEventListener('click', beginQuickMatch);
  document.getElementById('queue-cancel')?.addEventListener('click', () => {
    queueHandle?.cancel();
    queueHandle = null;
    stopQueueUi();
    if (modeSelect) modeSelect.hidden = false; // 回模式選單（可再進線上面板）
    blip(300, 0.08);
  });
  queueAiOffer?.addEventListener('click', () => {
    queueHandle?.cancel();
    queueHandle = null;
    stopQueueUi();
    startAiMode('normal');
  });

  // lobby START（FFA host）：resolve 開始訊號，按鈕隱藏避免重複觸發。
  lobbyStart?.addEventListener('click', () => {
    if (lobbyStart) { lobbyStart.disabled = true; lobbyStart.hidden = true; }
    if (lobbyWait) lobbyWait.textContent = '開局中…';
    resolveStart?.();
    resolveStart = null;
    blip(680, 0.08);
  });

  modeSelect?.querySelectorAll<HTMLElement>('[data-mode]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const m = btn.dataset.mode;
      if (m === 'solo') showSkillSelect('solo');
      else if (m === 'ai') showSkillSelect('ai', btn.dataset.diff);
      else if (m === 'online') showOnlinePanel();
    });
  });
  document.getElementById('online-wallet')?.addEventListener('click', () => void onConnectWallet());
  document.getElementById('profile-wallet')?.addEventListener('click', () => void onConnectWallet());
  document.getElementById('online-create')?.addEventListener('click', beginHost);
  document.getElementById('online-join-btn')?.addEventListener('click', beginJoin);

  // ---- 分頁切換 ----
  const tabs = Array.from(document.querySelectorAll<HTMLElement>('.mm-tab'));
  const panels: Record<string, HTMLElement | null> = {
    play: document.getElementById('panel-play'),
    leaderboard: document.getElementById('panel-leaderboard'),
    profile: document.getElementById('panel-profile'),
  };
  let lbLoaded = false;
  let activeTab = 'play';

  /** 分頁切換的故障掃頻音效：saw 由高到低「vwip」+ square 由低到高「ting」。 */
  function tabSound(): void {
    try {
      const Ctx = window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext;
      actx = actx ?? new Ctx();
      if (actx.state === 'suspended') void actx.resume();
      const t = actx.currentTime;
      const o1 = actx.createOscillator();
      const g1 = actx.createGain();
      o1.type = 'sawtooth';
      o1.frequency.setValueAtTime(880, t);
      o1.frequency.exponentialRampToValueAtTime(220, t + 0.08);
      g1.gain.setValueAtTime(0.045, t);
      g1.gain.exponentialRampToValueAtTime(0.0001, t + 0.1);
      o1.connect(g1).connect(actx.destination);
      o1.start(t); o1.stop(t + 0.11);
      const o2 = actx.createOscillator();
      const g2 = actx.createGain();
      o2.type = 'square';
      o2.frequency.setValueAtTime(520, t + 0.05);
      o2.frequency.exponentialRampToValueAtTime(900, t + 0.14);
      g2.gain.setValueAtTime(0.0001, t + 0.05);
      g2.gain.linearRampToValueAtTime(0.05, t + 0.07);
      g2.gain.exponentialRampToValueAtTime(0.0001, t + 0.16);
      o2.connect(g2).connect(actx.destination);
      o2.start(t + 0.05); o2.stop(t + 0.17);
    } catch { /* 音效非必要 */ }
  }

  /** 分頁切換的故障揭示：由上往下 clip 撕開 + skew 抖動 + 亮度/色偏爆閃（WAAPI，可重觸發）。 */
  function flashPanel(el: HTMLElement | null): void {
    if (!el || reduceMotion || typeof el.animate !== 'function') return;
    el.animate(
      [
        { clipPath: 'inset(0 0 100% 0)', opacity: 0.15, transform: 'translateY(-10px) skewX(-8deg) scale(0.98)', filter: 'brightness(3) saturate(1.8) hue-rotate(18deg)', offset: 0 },
        { clipPath: 'inset(0 0 45% 0)', opacity: 1, transform: 'translateX(7px) skewX(5deg)', filter: 'brightness(2)', offset: 0.3 },
        { clipPath: 'inset(0 0 12% 0)', opacity: 1, transform: 'translateX(-5px) skewX(-3deg)', filter: 'brightness(1.5)', offset: 0.55 },
        { clipPath: 'inset(0 0 0 0)', opacity: 1, transform: 'translateX(2px) skewX(1deg)', filter: 'brightness(1.2)', offset: 0.8 },
        { clipPath: 'inset(0 0 0 0)', opacity: 1, transform: 'none', filter: 'none', offset: 1 },
      ],
      { duration: 420, easing: 'cubic-bezier(0.2, 0.9, 0.2, 1)' },
    );
  }

  /** 把指示條移到 active 分頁底部（animate=false 用於初始/resize，不滑動）。 */
  function moveIndicator(animate: boolean): void {
    const ind = document.getElementById('mm-tab-ind');
    const tab = tabs.find((t) => t.dataset.tab === activeTab) ?? tabs[0];
    if (!ind || !tab) return;
    ind.style.transition = animate && !reduceMotion ? '' : 'none';
    ind.style.width = `${tab.offsetWidth}px`;
    ind.style.transform = `translate(${tab.offsetLeft}px, ${tab.offsetTop + tab.offsetHeight + 4}px)`;
  }

  function switchTab(name: string): void {
    const changed = name !== activeTab;
    tabs.forEach((t) => {
      const on = t.dataset.tab === name;
      t.classList.toggle('is-active', on);
      t.setAttribute('aria-selected', on ? 'true' : 'false');
      if (on && changed && !reduceMotion && typeof t.animate === 'function') {
        t.animate(
          [
            { transform: 'scale(1)', filter: 'brightness(1)' },
            { transform: 'scale(1.16)', filter: 'brightness(1.9)', offset: 0.4 },
            { transform: 'scale(1)', filter: 'brightness(1)' },
          ],
          { duration: 260, easing: 'cubic-bezier(0.2, 0.9, 0.2, 1)' },
        );
      }
    });
    for (const [key, el] of Object.entries(panels)) {
      if (!el) continue;
      const active = key === name;
      el.classList.toggle('is-active', active);
      el.hidden = !active;
    }
    if (name === 'play') {
      if (isTouch) {
        showTouchNotice();
      } else {
        // 還原模式選單：使用者可能先前點過「線上對戰」/快速配對/技能選擇步而隱藏了 SOLO/AI
        if (modeSelect) modeSelect.hidden = false;
        if (onlinePanel) onlinePanel.hidden = true;
        if (skillSelect) skillSelect.hidden = true;
        skillSelectOpen = false;
        if (queueHandle) { queueHandle.cancel(); queueHandle = null; } // 切走分頁＝棄排
        stopQueueUi();
      }
    }
    if (name === 'leaderboard' && !lbLoaded) { lbLoaded = true; void loadLeaderboard(); }
    if (name === 'profile' && wallet) void loadProfile(wallet.address);
    activeTab = name;
    moveIndicator(changed);
    if (changed) {
      flashPanel(panels[name]);
      tabSound();
    }
  }
  moveIndicator(false);
  if (document.fonts?.ready) void document.fonts.ready.then(() => moveIndicator(false));
  window.addEventListener('resize', () => moveIndicator(false));
  tabs.forEach((t, i) => {
    t.addEventListener('click', () => switchTab(t.dataset.tab ?? 'play'));
    // 方向鍵在分頁間移動焦點並切換（WAI-ARIA tablist 鍵盤模式）
    t.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      e.preventDefault();
      const dir = e.key === 'ArrowRight' ? 1 : -1;
      const next = tabs[(i + dir + tabs.length) % tabs.length];
      next.focus();
      switchTab(next.dataset.tab ?? 'play');
    });
  });

  // ---- 工具 ----
  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }
  function shortAddr(a: string): string {
    return a.length > 12 ? `${a.slice(0, 6)}…${a.slice(-4)}` : a;
  }

  // ---- 排行榜 ----
  interface LbRow { id: string; name?: string; level: number; rating: number; tier: string; wins: number; losses: number }
  async function loadLeaderboard(): Promise<void> {
    const list = document.getElementById('lb-list');
    if (!list) return;
    list.innerHTML = '<li class="lb-empty">載入中…</li>';
    try {
      const res = await fetch('/api/leaderboard?n=20');
      const data = (await res.json()) as { rows: LbRow[] };
      if (!data.rows.length) {
        list.innerHTML = '<li class="lb-empty"><img class="lb-empty-ico" src="/assets/games/tetris/icons/trophy.webp" alt="" /><br />尚無紀錄<br /><span class="lb-empty-sub">打一場排名賽，搶下頭香！</span></li>';
        return;
      }
      const head = '<li class="lb-row lb-head"><span>#</span><span>PLAYER</span><span>LV</span><span>TIER</span><span>ELO</span><span>W-L</span></li>';
      const body = data.rows
        .map((r, i) => {
          const who = r.name ? escapeHtml(r.name) : shortAddr(r.id);
          const cls = i === 0 ? 'lb-row lb-top' : 'lb-row';
          return `<li class="${cls}"><span class="lb-rank">${i + 1}</span><span class="lb-name">${who}</span><span class="lb-lv">Lv.${r.level}</span><span class="lb-tier">${escapeHtml(r.tier)}</span><span class="lb-rating">${r.rating}</span><span class="lb-wl">${r.wins}-${r.losses}</span></li>`;
        })
        .join('');
      list.innerHTML = head + body;
    } catch {
      list.innerHTML = '<li class="lb-empty">排行榜載入失敗</li>';
    }
  }

  // ---- 個人檔案 ----
  interface Profile { name: string | null; level: number; xp: number; progress: number; rating: number; tier: string; games: number; wins: number; losses: number; top3: number }
  async function loadProfile(addr: string): Promise<void> {
    const guest = document.getElementById('profile-guest');
    const stats = document.getElementById('profile-stats');
    if (!stats) return;
    if (guest) guest.hidden = true;
    stats.hidden = false;
    stats.innerHTML = '<p class="profile-guest">載入中…</p>';
    try {
      const res = await fetch(`/api/profile?addr=${encodeURIComponent(addr)}`);
      const data = (await res.json()) as { profile: Profile | null };
      const p = data.profile;
      renderSkinRack(p?.level ?? 0, addr); // 錢包玩家以 profile level 解鎖皮膚
      if (!p) {
        stats.innerHTML = '<p class="profile-guest">新玩家！打一場排名賽即可建立檔案。</p>';
        return;
      }
      const name = p.name ? escapeHtml(p.name) : shortAddr(addr);
      stats.innerHTML = [
        `<div class="pf-row"><span class="pf-k">玩家</span><span>${name}</span></div>`,
        `<div class="pf-row"><span class="pf-k">等級</span><span>Lv.${p.level}（XP ${p.xp}）</span></div>`,
        `<div class="pf-bar"><i></i></div>`,
        `<div class="pf-row"><span class="pf-k">積分</span><span>${p.rating} · ${p.tier}</span></div>`,
        `<div class="pf-row"><span class="pf-k">戰績</span><span>${p.games} 場 · ${p.wins} 勝 ${p.losses} 敗</span></div>`,
        `<div class="pf-row"><span class="pf-k">前三名次</span><span>${p.top3} 次</span></div>`,
      ].join('');
      const bar = stats.querySelector<HTMLElement>('.pf-bar > i');
      if (bar) bar.style.setProperty('width', `${Math.round(p.progress * 100)}%`);
    } catch {
      stats.innerHTML = '<p class="profile-guest">檔案載入失敗</p>';
    }
  }

  // ---- 皮膚櫃（PROFILE 分頁）----
  // key 一致性：皮膚櫃與開局（startSolo/startAiMode）同用 wallet?.address；
  // 未連錢包 → guest key（tetris-skin:guest）。
  let rackLevel = 0; // 訪客 0；錢包玩家由 loadProfile 更新
  const skinCards = Array.from(document.querySelectorAll<HTMLElement>('.skin-card'));
  function renderSkinRack(level: number, addr: string | null): void {
    rackLevel = level;
    // 防呆：選了未解鎖／未知皮膚 → 高亮顯示回退後的 neon
    const activeId = resolveSkin(getSelectedSkin(addr), level).id;
    skinCards.forEach((card) => {
      const skin = SKIN_CATALOG.find((s) => s.id === card.dataset.skin);
      if (!skin) return;
      const locked = !isUnlocked(skin, level);
      const active = skin.id === activeId;
      card.classList.toggle('is-active', active);
      card.classList.toggle('is-locked', locked);
      card.setAttribute('aria-disabled', locked ? 'true' : 'false');
      const state = card.querySelector<HTMLElement>('.skin-state');
      if (state) state.textContent = active ? '使用中' : locked ? `Lv ${skin.unlockLevel} 解鎖` : '已解鎖';
    });
    const cta = document.getElementById('skin-guest-cta');
    if (cta) cta.hidden = addr !== null; // 連錢包後收掉訪客提示
  }
  skinCards.forEach((card) => {
    card.addEventListener('click', () => {
      if (card.classList.contains('is-locked') || card.classList.contains('is-active')) return;
      const id = card.dataset.skin;
      if (!id) return;
      const addr = wallet?.address ?? null;
      setSelectedSkin(id, addr);
      renderSkinRack(rackLevel, addr); // 即時更新高亮，下一局生效
      blip(640, 0.06);
    });
  });
  renderSkinRack(0, null); // 訪客預設：level 0、guest key

  if (isTouch) showTouchNotice(); // 觸控裝置：PLAY 分頁直接顯示「請用電腦」提示

  // 深連結：?mode= 不出技能選擇步、直接開局（既有 e2e 合約）；?skill= 可帶技能。
  const mode = params.get('mode');
  const rawSkill = params.get('skill');
  const deepSkill: SkillId | null = rawSkill && rawSkill in SKILLS ? (rawSkill as SkillId) : null;
  if (mode === 'solo') startSolo(deepSkill === 'shield' ? null : deepSkill); // shield 僅 vs-AI
  else if (mode === 'ai') startAiMode(params.get('diff'), deepSkill);
  else if (mode === 'online') showOnlinePanel();
</script>
