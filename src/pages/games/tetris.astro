---
/**
 * /games/tetris — Dungeon Arcade 對戰俄羅斯方塊
 * 模式：SOLO / vs AI / 線上對戰；全螢幕 PixiJS 遊戲頁，由頁底腳本載入並 code-split。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import ArcadeBgm from '@components/ArcadeBgm.astro';
import { defaultLang, type Language } from '@i18n/index';
import { SKIN_CATALOG } from '@scripts/games/tetris/render/skins';
import { SKILLS } from '@scripts/games/tetris/engine/run';

const lang: Language = defaultLang;
// 技能卡靜態渲染（Astro scoped style 才會套上）；shield 由 JS 依模式顯隱。
const skillCards = Object.entries(SKILLS).map(([id, s]) => ({ id, name: s.name, desc: s.desc, aiOnly: Boolean(s.aiOnly) }));
---

<BaseLayout
  title="Dungeon Arcade — Battle Tetris"
  description="霓虹地城風格的對戰俄羅斯方塊"
  lang={lang}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
  />

  <main class="tetris-page">
    <a class="tetris-back" href="/games">← ARCADE</a>
    <p class="tetris-hint" id="tetris-hint" hidden>MOVE ←→ · ROTATE ↑/Z · DROP SPACE · HOLD SHIFT · MUTE M</p>
    <div class="tetris-stage">
      <canvas id="tetris-canvas"></canvas>
    </div>

    <div class="main-menu" id="main-menu">
      <img class="mm-logo" src="/assets/games/tetris/logo-battle-tetris.webp" alt="BATTLE TETRIS" />
      <nav class="mm-tabs" role="tablist" aria-label="遊戲選單">
        <button class="mm-tab is-active" data-tab="play" type="button" role="tab" aria-selected="true">PLAY</button>
        <button class="mm-tab" data-tab="leaderboard" type="button" role="tab" aria-selected="false">LEADERBOARD</button>
        <button class="mm-tab" data-tab="profile" type="button" role="tab" aria-selected="false">PROFILE</button>
        <span class="mm-tab-ind" id="mm-tab-ind" aria-hidden="true"></span>
      </nav>

      <section class="mm-panel is-active" id="panel-play">
        <div class="mode-select" id="mode-select">
          <div class="ms-buttons">
            <button class="ms-btn ms-quick" id="quick-match">QUICK MATCH</button>
            <button class="ms-btn ms-solo" data-mode="solo">SOLO</button>
            <button class="ms-btn" data-mode="ai" data-diff="easy">vs AI · EASY</button>
            <button class="ms-btn" data-mode="ai" data-diff="normal">vs AI · NORMAL</button>
            <button class="ms-btn ms-hard" data-mode="ai" data-diff="hard">vs AI · HARD</button>
            <button class="ms-btn ms-insane" data-mode="ai" data-diff="insane" title="神級 AI：人類無法戰勝">vs AI · INSANE<span class="ms-sub">人類無法戰勝</span></button>
            <button class="ms-btn ms-online" data-mode="online">vs ONLINE</button>
          </div>
          <button class="handling-open" id="handling-open" type="button" aria-expanded="false" aria-controls="handling-panel">HANDLING 手感設定</button>
          <div class="handling-panel" id="handling-panel" hidden>
            <div class="hp-row">
              <label class="hp-label" for="handling-das">DAS</label>
              <input class="hp-slider" id="handling-das" type="range" min="50" max="300" step="5" data-handling="das" />
              <span class="hp-val" id="handling-das-val">150ms</span>
            </div>
            <div class="hp-row">
              <label class="hp-label" for="handling-arr">ARR</label>
              <input class="hp-slider" id="handling-arr" type="range" min="0" max="80" step="5" data-handling="arr" />
              <span class="hp-val" id="handling-arr-val">35ms</span>
            </div>
            <div class="hp-row">
              <label class="hp-label" for="handling-sdf">SDF</label>
              <input class="hp-slider" id="handling-sdf" type="range" min="0" max="60" step="5" data-handling="sdf" />
              <span class="hp-val" id="handling-sdf-val">30ms</span>
            </div>
            <p class="hp-hint">ARR 0 = 瞬移 · SDF 0 = 瞬降 · 調整於下一局生效</p>
            <div class="hp-actions">
              <button class="ms-btn hp-btn" id="handling-reset" type="button">恢復預設</button>
              <button class="ms-btn ms-solo hp-btn" id="handling-done" type="button">完成</button>
            </div>
          </div>
        </div>
        <div class="mode-select" id="skill-select" hidden>
          <h2 class="ss-title">SELECT SKILL</h2>
          <div class="ss-cards">
            {skillCards.map((s) => (
              <button type="button" class="ss-card" data-skill={s.id} data-aionly={s.aiOnly ? 'true' : null}>
                <span class="ss-key" aria-hidden="true"></span>
                <span class={`ss-ico ss-ico--${s.id}`}></span>
                <span class="ss-meta">
                  <span class="ss-name">{s.name}</span>
                  <span class="ss-desc">{s.desc}</span>
                </span>
              </button>
            ))}
            <button type="button" class="ss-card" data-skill="">
              <span class="ss-key" aria-hidden="true"></span>
              <span class="ss-ico ss-ico--none"></span>
              <span class="ss-meta">
                <span class="ss-name">不帶技能</span>
                <span class="ss-desc">純粹手速，不靠技能輔助</span>
              </span>
            </button>
          </div>
          <p class="ss-hint">按 1-5 快選 · 或點選卡片 · 遊戲中按 V 發動</p>
        </div>
        <div class="mode-select" id="online-panel" hidden>
          <div class="ms-buttons">
            <input id="online-name" class="online-input" maxlength="12" placeholder="暱稱（選填）" autocomplete="off" />
            <button class="ms-btn ms-wallet" id="online-wallet">連錢包打排名賽</button>
            <div class="player-count" id="player-count" role="group" aria-label="玩家人數">
              <span class="pc-label">人數</span>
              <div class="pc-options" id="pc-options">
                <button class="pc-btn is-active" type="button" data-count="2" aria-pressed="true">2</button>
                <button class="pc-btn" type="button" data-count="3">3</button>
                <button class="pc-btn" type="button" data-count="4">4</button>
                <button class="pc-btn" type="button" data-count="5">5</button>
                <button class="pc-btn" type="button" data-count="6">6</button>
                <button class="pc-btn" type="button" data-count="7">7</button>
                <button class="pc-btn" type="button" data-count="8">8</button>
              </div>
            </div>
            <button class="ms-btn ms-online" id="online-create">建立房間</button>
            <div class="online-join">
              <input id="online-room" class="online-input" maxlength="5" placeholder="房號" autocomplete="off" />
              <button class="ms-btn" id="online-join-btn">加入房間</button>
            </div>
            <p class="online-status" id="online-status"></p>
          </div>
        </div>
        <div class="mode-select" id="queue-panel" hidden>
          <h2 class="ss-title">QUICK MATCH</h2>
          <p class="queue-status" id="queue-status">正在尋找玩家…</p>
          <p class="queue-timer">已等待 <span id="queue-seconds">0</span> 秒</p>
          <div class="ms-buttons">
            <button class="ms-btn ms-solo" id="queue-ai-offer" type="button" hidden>目前沒有玩家排隊，先跟 AI 打一場？</button>
            <button class="ms-btn ms-hard" id="queue-cancel" type="button">取消排隊</button>
          </div>
        </div>
        <p class="touch-notice" id="touch-notice" hidden>
          本遊戲需用<strong>電腦鍵盤</strong>遊玩。<br />
          手機／觸控裝置請改用桌機開啟；<br />你仍可切換上方分頁查看排行榜與個人檔案。
        </p>
        <div class="online-lobby" id="online-lobby" hidden>
          <p class="lobby-label">房號 ROOM</p>
          <div class="lobby-code-row">
            <span class="lobby-code" id="lobby-code">·····</span>
            <button class="ms-btn lobby-copy" id="lobby-copy" type="button">複製</button>
          </div>
          <p class="lobby-count" id="lobby-count" hidden>已加入 <strong id="lobby-joined">1</strong> / <span id="lobby-target">4</span> 人</p>
          <p class="lobby-wait" id="lobby-wait">等待對手加入…</p>
          <button class="ms-btn ms-solo lobby-start" id="lobby-start" type="button" hidden>開始</button>
          <button class="ms-btn ms-hard" id="lobby-cancel" type="button">取消</button>
        </div>
      </section>

      <section class="mm-panel" id="panel-leaderboard" hidden>
        <h2 class="ms-title">LEADERBOARD</h2>
        <ol class="lb-list" id="lb-list"><li class="lb-empty">載入中…</li></ol>
      </section>

      <section class="mm-panel" id="panel-profile" hidden>
        <h2 class="ms-title">PROFILE</h2>
        <p class="profile-guest" id="profile-guest">訪客無等級／積分。<br />連錢包以建立你的玩家檔案。</p>
        <button class="ms-btn ms-wallet" id="profile-wallet">連錢包</button>
        <div class="profile-stats" id="profile-stats" hidden></div>
        <div class="skin-rack" id="skin-rack">
          <h3 class="skin-rack-title">SKINS</h3>
          <div class="skin-cards" id="skin-cards">
            {SKIN_CATALOG.map((s) => (
              <button
                type="button"
                class:list={['skin-card', { 'is-active': s.unlockLevel === 0, 'is-locked': s.unlockLevel > 0 }]}
                data-skin={s.id}
                aria-disabled={s.unlockLevel > 0 ? 'true' : 'false'}
              >
                <span class={`skin-thumb skin-thumb--${s.id}`}></span>
                <span class="skin-name">{s.name}</span>
                <span class="skin-state">{s.unlockLevel === 0 ? '使用中' : `Lv ${s.unlockLevel} 解鎖`}</span>
              </button>
            ))}
          </div>
          <p class="skin-guest-cta" id="skin-guest-cta">連接錢包並升級以解鎖更多皮膚</p>
        </div>
      </section>
    </div>

    <div class="pause-menu" id="pause-menu" hidden>
      <div class="pause-card">
        <h2 class="pause-title" id="pause-title">PAUSED</h2>
        <p class="pause-hint" id="pause-hint" hidden>離開將判敗（排名局計入名次）</p>
        <button class="ms-btn ms-solo" id="pause-resume" type="button">繼續</button>
        <button class="ms-btn ms-hard" id="pause-quit" type="button">離開</button>
      </div>
    </div>

    <div class="pause-menu" id="result-menu" hidden>
      <div class="pause-card">
        <h2 class="pause-title" id="result-title">GAME OVER</h2>
        <button class="ms-btn ms-solo" id="result-again" type="button">再玩一次</button>
        <button class="ms-btn ms-hard" id="result-quit" type="button">離開</button>
      </div>
    </div>

    <!-- SOLO 升級三選一（perk 覆蓋層；文字由 JS 填，開啟時與 ESC 暫停互斥） -->
    <div class="pause-menu" id="perk-menu" hidden>
      <div class="pause-card perk-box">
        <h2 class="pause-title">LEVEL UP</h2>
        <p class="perk-sub">選擇一項強化 · 鍵盤 1 / 2 / 3</p>
        <div class="perk-cards">
          <button class="perk-card" type="button" data-slot="0">
            <span class="perk-key">1</span>
            <span class="perk-name"></span>
            <span class="perk-desc"></span>
          </button>
          <button class="perk-card" type="button" data-slot="1">
            <span class="perk-key">2</span>
            <span class="perk-name"></span>
            <span class="perk-desc"></span>
          </button>
          <button class="perk-card" type="button" data-slot="2">
            <span class="perk-key">3</span>
            <span class="perk-name"></span>
            <span class="perk-desc"></span>
          </button>
        </div>
      </div>
    </div>
  </main>
  <ArcadeBgm track="/assets/games/bgm/tetris.mp3" />
</BaseLayout>

<style>
  .tetris-page {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background:
      radial-gradient(ellipse at 50% 32%, rgba(54, 230, 255, 0.08), transparent 60%),
      linear-gradient(180deg, rgba(4, 6, 13, 0.84), rgba(4, 6, 13, 0.93)),
      url('/assets/games/tetris/bg-dungeon.webp') center / cover no-repeat;
    overflow: hidden;
  }
  .tetris-stage {
    position: absolute;
    inset: 0;
  }
  #tetris-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .tetris-back {
    position: absolute;
    top: 18px;
    left: 20px;
    z-index: 40; /* 高於主選單(20)/暫停(30) 全螢幕層，確保可點 */
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: #9fcdf2;
    text-shadow: 0 0 8px rgba(54, 230, 255, 0.45);
    text-decoration: none;
    opacity: 1;
  }
  .tetris-back:hover {
    color: #36e6ff;
  }
  .tetris-hint {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    z-index: 10;
    margin: 0;
    text-align: center;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: #5a7299;
    opacity: 0.75;
    pointer-events: none;
  }
  .mode-select {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    font-family: 'Press Start 2P', Consolas, monospace;
  }
  .ms-title {
    margin: 0;
    font-size: clamp(18px, 3.5vw, 30px);
    letter-spacing: 4px;
    color: #eafdff;
    text-shadow: 0 0 12px rgba(54, 230, 255, 0.9), 0 0 28px rgba(54, 230, 255, 0.5);
  }
  .ms-buttons {
    display: flex;
    flex-direction: column;
    gap: 11px;
    width: 100%;
  }
  .ms-btn {
    padding: 15px 20px;
    font-family: inherit;
    font-size: 13px;
    letter-spacing: 2px;
    color: #cfe8ff;
    background: rgba(8, 12, 22, 0.8);
    border: 2px solid rgba(54, 230, 255, 0.7);
    border-radius: 10px;
    box-shadow: 0 0 12px rgba(54, 230, 255, 0.3);
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, color 0.15s ease;
  }
  .ms-btn:hover {
    transform: translateY(-3px);
    color: #eafdff;
    box-shadow: 0 0 22px rgba(54, 230, 255, 0.75);
  }
  .ms-solo { border-color: rgba(77, 255, 136, 0.7); box-shadow: 0 0 12px rgba(77, 255, 136, 0.3); }
  .ms-solo:hover { box-shadow: 0 0 22px rgba(77, 255, 136, 0.75); }
  .ms-hard { border-color: rgba(255, 77, 109, 0.7); box-shadow: 0 0 12px rgba(255, 77, 109, 0.3); }
  .ms-hard:hover { box-shadow: 0 0 22px rgba(255, 77, 109, 0.8); }
  /* INSANE：神級超級模式（原 hard 參數）——紫紅警示霓虹 + 副標警語 */
  .ms-insane {
    color: #ffd2f2;
    border-color: rgba(255, 45, 168, 0.8);
    box-shadow: 0 0 12px rgba(255, 45, 168, 0.35), inset 0 0 18px rgba(168, 32, 255, 0.18);
  }
  .ms-insane:hover {
    color: #ffeafa;
    box-shadow: 0 0 26px rgba(255, 45, 168, 0.85), inset 0 0 22px rgba(168, 32, 255, 0.3);
  }
  .ms-sub {
    display: block;
    margin-top: 6px;
    font-size: 8px;
    letter-spacing: 3px;
    color: #ff5ec4;
    text-shadow: 0 0 8px rgba(255, 45, 168, 0.6);
  }
  .ms-online { border-color: rgba(193, 92, 255, 0.7); box-shadow: 0 0 12px rgba(193, 92, 255, 0.3); }
  .ms-online:hover { box-shadow: 0 0 22px rgba(193, 92, 255, 0.8); }
  .ms-wallet { border-color: rgba(255, 210, 63, 0.7); box-shadow: 0 0 12px rgba(255, 210, 63, 0.3); font-size: 11px; }
  .ms-wallet:hover { box-shadow: 0 0 22px rgba(255, 210, 63, 0.8); }
  .ms-wallet.connected { border-color: rgba(77, 255, 136, 0.8); color: #4dff88; }

  .mode-select[hidden] { display: none; }

  /* HANDLING 手感設定（PLAY 分頁，mode-select 下方小連結 → 滑桿面板） */
  .handling-open {
    font-family: inherit;
    font-size: 9px;
    letter-spacing: 1px;
    color: #6fa8d8;
    background: transparent;
    border: none;
    padding: 4px 8px;
    cursor: pointer;
    transition: color 0.15s ease, text-shadow 0.15s ease;
  }
  .handling-open:hover {
    color: #36e6ff;
    text-shadow: 0 0 8px rgba(54, 230, 255, 0.6);
  }
  .handling-panel {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    padding: 14px 16px;
    background: rgba(8, 12, 22, 0.8);
    border: 1px solid rgba(54, 230, 255, 0.35);
    border-radius: 10px;
  }
  .handling-panel[hidden] { display: none; }
  .hp-row {
    display: grid;
    grid-template-columns: 3.2em 1fr 4.4em;
    align-items: center;
    gap: 10px;
  }
  .hp-label {
    font-size: 10px;
    letter-spacing: 1px;
    color: #9fcdf2;
  }
  .hp-slider {
    width: 100%;
    height: 18px;
    accent-color: #36e6ff;
    background: transparent;
    cursor: pointer;
  }
  .hp-val {
    font-size: 9px;
    letter-spacing: 1px;
    text-align: right;
    color: #4dff88;
  }
  .hp-hint {
    margin: 0;
    font-size: 8px;
    letter-spacing: 1px;
    line-height: 1.7;
    text-align: center;
    color: #5a7299;
  }
  .hp-actions {
    display: flex;
    gap: 10px;
  }
  .hp-btn {
    flex: 1;
    padding: 10px 12px;
    font-size: 10px;
  }
  .online-join { display: flex; gap: 10px; align-items: stretch; }
  #online-join-btn { white-space: nowrap; flex: 0 0 auto; padding-left: 16px; padding-right: 16px; }
  .online-input {
    flex: 1;
    padding: 14px;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 14px;
    letter-spacing: 3px;
    text-align: center;
    text-transform: uppercase;
    color: #eafdff;
    background: rgba(8, 12, 22, 0.85);
    border: 2px solid rgba(54, 230, 255, 0.6);
    border-radius: 10px;
  }
  .online-status {
    margin: 6px 0 0;
    min-height: 1.4em;
    text-align: center;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 10px;
    line-height: 1.6;
    letter-spacing: 1px;
    color: #9fb4d8;
  }

  /* 快速配對（QUICK MATCH）：入口按鈕金色霓虹 + 排隊面板 */
  .ms-quick {
    border-color: rgba(255, 210, 63, 0.7);
    box-shadow: 0 0 12px rgba(255, 210, 63, 0.3);
    color: #ffe9a8;
  }
  .ms-quick:hover { box-shadow: 0 0 22px rgba(255, 210, 63, 0.8); }
  .ms-quick::before {
    content: '';
    display: inline-block;
    width: 1.3em;
    height: 1.3em;
    margin-right: 8px;
    vertical-align: -0.28em;
    background: url('/assets/games/tetris/icons/play.webp') center / contain no-repeat;
  }
  .queue-status {
    margin: 0;
    min-height: 1.4em;
    text-align: center;
    font-size: 11px;
    line-height: 1.8;
    letter-spacing: 1px;
    color: #cfe9ff;
    animation: lobbyPulse 1.4s ease-in-out infinite;
  }
  .queue-timer {
    margin: 0;
    text-align: center;
    font-size: 10px;
    letter-spacing: 1px;
    color: #6fa8d8;
  }
  .queue-timer span {
    color: #ffd23f;
    font-size: 13px;
  }
  #queue-ai-offer { font-size: 10px; line-height: 1.8; letter-spacing: 1px; }
  #queue-ai-offer[hidden] { display: none; }

  /* 開局技能選擇步（SOLO / vs-AI）*/
  .ss-title {
    margin: 0;
    font-size: clamp(14px, 2.4vw, 20px);
    letter-spacing: 3px;
    color: #eafdff;
    text-shadow: 0 0 12px rgba(54, 230, 255, 0.9), 0 0 28px rgba(54, 230, 255, 0.5);
  }
  .ss-cards {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
  }
  .ss-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    font-family: inherit;
    text-align: left;
    color: #cfe8ff;
    background: rgba(8, 12, 22, 0.8);
    border: 2px solid rgba(54, 230, 255, 0.55);
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, color 0.15s ease;
  }
  .ss-card:hover {
    transform: translateY(-2px);
    color: #eafdff;
    box-shadow: 0 0 18px rgba(54, 230, 255, 0.6);
  }
  .ss-card[hidden] { display: none; }
  .ss-key {
    flex: 0 0 auto;
    min-width: 1.6em;
    font-size: 10px;
    letter-spacing: 0;
    color: #ffd23f;
  }
  .ss-ico {
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    background: center / contain no-repeat;
  }
  .ss-ico--bomb { background-image: url('/assets/games/tetris/icons/skill-bomb.webp'); }
  .ss-ico--slow { background-image: url('/assets/games/tetris/icons/skill-slow.webp'); }
  .ss-ico--reroll { background-image: url('/assets/games/tetris/icons/skill-reroll.webp'); }
