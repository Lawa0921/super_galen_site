---
/**
 * /games/tetris — Dungeon Arcade 對戰俄羅斯方塊（Phase 2：單人可玩）
 * 全螢幕 PixiJS 遊戲頁；Pixi 透過下方 <script> import，由 Vite code-split 至本頁。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import { defaultLang, type Language } from '@i18n/index';

const lang: Language = defaultLang;
---

<BaseLayout
  title="Dungeon Arcade — Battle Tetris"
  description="霓虹地城風格的對戰俄羅斯方塊"
  lang={lang}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
  />

  <main class="tetris-page">
    <a class="tetris-back" href="/games">← ARCADE</a>
    <p class="tetris-hint">MOVE ←→ · ROTATE ↑/Z · DROP SPACE · HOLD SHIFT · MUTE M</p>
    <div class="tetris-stage">
      <canvas id="tetris-canvas"></canvas>
    </div>
  </main>
</BaseLayout>

<style>
  .tetris-page {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background: #04060d;
    overflow: hidden;
  }
  .tetris-stage {
    position: absolute;
    inset: 0;
  }
  #tetris-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  .tetris-back {
    position: absolute;
    top: 18px;
    left: 20px;
    z-index: 10;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: #6fa8d8;
    text-decoration: none;
    opacity: 0.8;
  }
  .tetris-back:hover {
    opacity: 1;
    color: #36e6ff;
  }
  .tetris-hint {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    z-index: 10;
    margin: 0;
    text-align: center;
    font-family: 'Press Start 2P', Consolas, monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: #5a7299;
    opacity: 0.75;
    pointer-events: none;
  }
</style>

<script>
  import { startTetris } from '@scripts/games/tetris/render/main';

  const canvas = document.getElementById('tetris-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    startTetris(canvas).catch((err) => {
      console.error('[tetris] failed to start', err);
    });
  }
</script>
