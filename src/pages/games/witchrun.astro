---
/**
 * /games/witchrun — Dungeon Arcade: WITCH RUN
 * Mira 主演縱向彈幕。全螢幕 PixiJS，頁底腳本 code-split 載入。
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import { defaultLang, type Language } from '@i18n/index';

const lang: Language = defaultLang;
---

<BaseLayout title="Dungeon Arcade — Witch Run" description="像素縱向彈幕：詛咒鐘塔" lang={lang}>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" />

  <main class="witch" data-phase="title">
    <canvas id="witch-canvas"></canvas>

    <!-- 標題畫面 -->
    <div class="witch-title" id="witch-title">
      <div class="witch-title-art" aria-hidden="true"></div>
      <div class="witch-embers" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <a class="witch-home" href="/games">← ARCADE</a>
      <div class="witch-title-fg">
        <h1 class="witch-logo">WITCH RUN</h1>
        <p class="witch-tagline">THE CURSED BELLTOWER</p>
        <p class="witch-story">月蝕之夜，亡鐘自鳴。爆彈魔女 Mira 騎上掃帚——在鐘聲敲滿十二響前，飛抵塔頂封印它。</p>
        <button class="witch-start" id="witch-start" type="button">START</button>
        <p class="witch-keys">MOVE 方向鍵/WASD · FOCUS Shift · BOMB X · OVERDRIVE Z</p>
      </div>
    </div>

    <!-- 選角畫面（電影聚光輪播） -->
    <div class="witch-select" id="witch-select" hidden>
      <div class="select-bg" aria-hidden="true"></div>
      <div class="select-aura" aria-hidden="true"></div>
      <button class="witch-home select-back" id="select-back" type="button">← BACK</button>
      <h2 class="select-heading">CHOOSE YOUR WITCH</h2>
      <div class="select-stage">
        <button class="select-arrow" id="select-prev" type="button" aria-label="上一位">◄</button>
        <div class="select-portrait-wrap">
          <img class="select-portrait" id="select-portrait" alt="" decoding="async" />
        </div>
        <button class="select-arrow" id="select-next" type="button" aria-label="下一位">►</button>
      </div>
      <div class="select-info">
        <p class="select-name" id="select-name">MIRA</p>
        <p class="select-school" id="select-school">爆炎 · INFERNO</p>
        <p class="select-blurb" id="select-blurb"></p>
        <div class="select-stats" id="select-stats"></div>
      </div>
      <div class="select-dots" id="select-dots" aria-hidden="true"></div>
      <button class="witch-start" id="select-confirm" type="button">START</button>
    </div>

    <!-- 遺物三選一 -->
    <div class="witch-overlay" id="witch-draft" hidden>
      <h2 class="overlay-heading">CHOOSE A RELIC</h2>
      <div class="draft-row">
        <button class="relic-card" type="button" data-relic-slot="0">
          <span class="relic-name"></span><span class="relic-desc"></span>
        </button>
        <button class="relic-card" type="button" data-relic-slot="1">
          <span class="relic-name"></span><span class="relic-desc"></span>
        </button>
        <button class="relic-card" type="button" data-relic-slot="2">
          <span class="relic-name"></span><span class="relic-desc"></span>
        </button>
      </div>
    </div>

    <!-- Game Over -->
    <div class="witch-overlay" id="witch-over" hidden>
      <h2 class="overlay-heading" id="witch-over-heading">GAME OVER</h2>
      <p class="overlay-stats" id="witch-over-stats"></p>
      <button class="witch-start" id="witch-continue" type="button">CONTINUE</button>
      <a class="overlay-link" href="/games">BACK TO ARCADE</a>
    </div>

    <!-- 通關 -->
    <div class="witch-overlay" id="witch-clear" hidden>
      <h2 class="overlay-heading">THE BELL IS SEALED</h2>
      <p class="overlay-stats" id="witch-clear-stats"></p>
      <a class="overlay-link" href="/games">BACK TO ARCADE</a>
    </div>

    <!-- 觸控按鈕 -->
    <div class="witch-touch" aria-hidden="true">
      <button class="touch-btn" id="witch-btn-bomb" type="button">BOMB</button>
      <button class="touch-btn touch-btn--od" id="witch-btn-od" type="button">OD</button>
    </div>
  </main>
</BaseLayout>

<style>
  .witch {
    position: fixed;
    inset: 0;
    background: #0a0716;
    font-family: 'Press Start 2P', Consolas, monospace;
  }
  #witch-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

  .witch-title {
    position: absolute; inset: 0; z-index: 10;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background: #0a0716; overflow: hidden;
    padding: 24px; text-align: center;
    transition: opacity 0.45s ease;
  }
  .witch-title[data-exit] { opacity: 0; pointer-events: none; }

  /* 活背景：arcade key art 緩慢推鏡（ken-burns），讓首屏「活」起來 */
  .witch-title-art {
    position: absolute; inset: 0; z-index: 0;
    background: url('/assets/games/witchrun/card-witchrun.webp') center 32% / cover no-repeat;
    opacity: 0.58;
    transform-origin: 50% 38%;
    animation: witch-drift 26s ease-in-out infinite alternate;
  }
  /* 壓暗＋洋紅暈染，確保前景文字可讀 */
  .witch-title::after {
    content: ''; position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 26%, rgba(255, 90, 77, 0.2), transparent 56%),
      linear-gradient(180deg, rgba(10, 7, 22, 0.5) 0%, rgba(10, 7, 22, 0.74) 58%, rgba(10, 7, 22, 0.95) 100%);
  }
  @keyframes witch-drift {
    from { transform: scale(1.05) translateY(0); }
    to   { transform: scale(1.14) translateY(-2.5%); }
  }

  /* 上升餘燼 */
  .witch-embers { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
  .witch-embers span {
    position: absolute; bottom: -14px; width: 4px; height: 4px; border-radius: 50%;
    background: #ff8a5a; box-shadow: 0 0 8px 2px rgba(255, 122, 77, 0.7);
    animation: witch-ember linear infinite;
  }
  .witch-embers span:nth-child(1)  { left: 8%;  animation-duration: 7.5s;  animation-delay: 0s;   }
  .witch-embers span:nth-child(2)  { left: 18%; animation-duration: 9s;    animation-delay: 1.4s; }
  .witch-embers span:nth-child(3)  { left: 29%; animation-duration: 6.5s;  animation-delay: 3s;   }
  .witch-embers span:nth-child(4)  { left: 40%; animation-duration: 10s;   animation-delay: 0.8s; width: 3px; height: 3px; }
  .witch-embers span:nth-child(5)  { left: 50%; animation-duration: 8s;    animation-delay: 2.2s; }
  .witch-embers span:nth-child(6)  { left: 61%; animation-duration: 9.5s;  animation-delay: 4s;   width: 3px; height: 3px; }
  .witch-embers span:nth-child(7)  { left: 71%; animation-duration: 7s;    animation-delay: 1s;   }
  .witch-embers span:nth-child(8)  { left: 82%; animation-duration: 11s;   animation-delay: 2.8s; }
  .witch-embers span:nth-child(9)  { left: 90%; animation-duration: 8.5s;  animation-delay: 0.4s; width: 3px; height: 3px; }
  .witch-embers span:nth-child(10) { left: 95%; animation-duration: 7.8s;  animation-delay: 3.6s; }
  @keyframes witch-ember {
    0%   { transform: translateY(0) scale(1);   opacity: 0; }
    12%  { opacity: 0.85; }
    88%  { opacity: 0.6; }
    100% { transform: translateY(-100vh) scale(0.35); opacity: 0; }
  }

  /* 前景內容置於裝飾層之上 */
  .witch-title-fg {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center; gap: 22px;
    max-width: 540px;
  }

  .witch-home { position: absolute; top: 18px; left: 20px; z-index: 3; font-size: 11px; color: #6fa8d8; text-decoration: none; }
  .witch-logo {
    margin: 0; font-size: clamp(24px, 6vw, 52px); letter-spacing: 6px; color: #ff5a4d;
    text-shadow: 0 0 14px rgba(255, 90, 77, 0.8), 0 0 40px rgba(255, 90, 77, 0.4);
  }
  .witch-tagline { margin: 0; font-size: 11px; letter-spacing: 4px; color: #9a8ac0; }
  .witch-story { max-width: 480px; font-size: 10px; line-height: 2; color: #c8bce0; }
  .witch-start {
    font-family: inherit; font-size: 14px; letter-spacing: 3px; color: #0a0716;
    background: #ff5a4d; border: none; border-radius: 8px; padding: 14px 38px; cursor: pointer;
    box-shadow: 0 0 18px rgba(255, 90, 77, 0.6);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .witch-start:hover { transform: translateY(-2px); box-shadow: 0 0 30px rgba(255, 90, 77, 0.9); }
  .witch-keys { font-size: 8px; letter-spacing: 1px; color: #6a5a9a; }

  /* 矮螢幕（手機橫向／小高度）：收斂垂直節奏，避免重心偏低、頂部過空 */
  @media (max-height: 720px) {
    .witch-title-fg { gap: 14px; }
    .witch-story { line-height: 1.8; }
  }
  @media (max-height: 560px) {
    .witch-title-fg { gap: 10px; }
    .witch-story { display: none; }
  }
  @media (max-width: 400px) {
    .witch-title-fg { gap: 16px; }
    .witch-title-art { background-position: center 28%; }
  }

  /* 尊重 reduced-motion：停掉推鏡與餘燼 */
  @media (prefers-reduced-motion: reduce) {
    .witch-title-art { animation: none; transform: scale(1.06); }
    .witch-embers { display: none; }
  }

  .witch-overlay {
    position: absolute; inset: 0; z-index: 20;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20px;
    background: rgba(10, 7, 22, 0.88); padding: 24px; text-align: center;
  }
  .witch-overlay[hidden] { display: none; }
  .overlay-heading { margin: 0; font-size: clamp(16px, 4vw, 28px); letter-spacing: 4px; color: #ffd23f; text-shadow: 0 0 12px rgba(255, 210, 63, 0.7); }
  .overlay-stats { font-size: 11px; color: #eafdff; letter-spacing: 2px; }
  .overlay-link { font-size: 10px; color: #6fa8d8; text-decoration: none; letter-spacing: 2px; }

  .draft-row { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
  .relic-card {
    width: 168px; min-height: 150px; display: flex; flex-direction: column; gap: 12px;
    align-items: center; justify-content: center; padding: 14px;
    font-family: inherit; cursor: pointer;
    background: rgba(26, 16, 48, 0.92); border: 2px solid rgba(154, 107, 255, 0.65); border-radius: 10px;
    box-shadow: 0 0 14px rgba(154, 107, 255, 0.3);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .relic-card:hover { transform: translateY(-4px); box-shadow: 0 0 26px rgba(154, 107, 255, 0.7); }
  .relic-card--rare {
    border-color: rgba(255, 210, 63, 0.85);
    box-shadow: 0 0 18px rgba(255, 210, 63, 0.45), 0 0 6px rgba(255, 210, 63, 0.25) inset;
  }
  .relic-card--rare:hover { box-shadow: 0 0 32px rgba(255, 210, 63, 0.8), 0 0 10px rgba(255, 210, 63, 0.35) inset; }
  .relic-name { font-size: 12px; color: #d0baff; letter-spacing: 1px; }
  .relic-desc { font-size: 9px; line-height: 1.8; color: #9a8ac0; }

  .witch-touch { position: absolute; right: 14px; bottom: 18px; z-index: 5; display: none; gap: 12px; }
  /* 觸控鈕只在實際遊玩、且無 overlay 開啟時顯示，避免在 title/overlay 半透明層下透出 */
  .touch-btn {
    width: 72px; height: 72px; border-radius: 50%; font-family: inherit; font-size: 10px;
    color: #ffd0c8; background: rgba(255, 90, 77, 0.25); border: 2px solid rgba(255, 90, 77, 0.7);
  }
  .touch-btn--od { color: #d0f4ff; background: rgba(54, 230, 255, 0.2); border-color: rgba(54, 230, 255, 0.7); }
  @media (pointer: coarse) { .witch[data-phase="playing"]:not([data-overlay]) .witch-touch { display: flex; } }

  /* ---- 選角畫面（電影聚光輪播）---- */
  .witch-select {
    --aura: #ff5a4d;
    position: absolute; inset: 0; z-index: 12;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
    padding: 20px; text-align: center; overflow: hidden;
    background: #0a0716;
    animation: witch-select-in 0.35s ease;
  }
  .witch-select[hidden] { display: none; }
  @keyframes witch-select-in { from { opacity: 0; } to { opacity: 1; } }

  /* 背景：所選角色立繪的模糊暗化版（切換時整體氛圍隨角色變色） */
  .select-bg {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background: var(--bg, none) center 22% / cover no-repeat;
    filter: blur(16px) brightness(0.45) saturate(1.1);
    transform: scale(1.15);
    opacity: 0.7;
  }
  /* 流派色光暈（隨選中角色換色） */
  .select-aura {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: radial-gradient(ellipse at 50% 42%, color-mix(in srgb, var(--aura) 32%, transparent), transparent 62%);
    transition: background 0.3s ease;
    animation: select-aura-pulse 4s ease-in-out infinite alternate;
  }
  @keyframes select-aura-pulse { from { opacity: 0.7; } to { opacity: 1; } }

  .select-back { position: absolute; top: 16px; left: 18px; z-index: 3; background: none; border: none; font-family: inherit; cursor: pointer; }
  .select-heading {
    position: relative; z-index: 2; margin: 0; font-size: clamp(13px, 3.4vw, 20px); letter-spacing: 4px;
    color: #eafdff; text-shadow: 0 0 12px var(--aura);
  }

  .select-stage {
    position: relative; z-index: 2;
    display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%;
  }
  .select-arrow {
    flex: none; width: 48px; height: 48px; border-radius: 50%; cursor: pointer;
    font-family: inherit; font-size: 16px; color: #fff;
    background: color-mix(in srgb, var(--aura) 22%, rgba(10, 7, 22, 0.6));
    border: 2px solid color-mix(in srgb, var(--aura) 70%, transparent);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .select-arrow:hover { transform: scale(1.08); box-shadow: 0 0 16px var(--aura); }
  .select-portrait-wrap {
    width: min(56vw, 232px); aspect-ratio: 3 / 4; border-radius: 12px; overflow: hidden;
    border: 2px solid color-mix(in srgb, var(--aura) 80%, transparent);
    box-shadow: 0 0 28px color-mix(in srgb, var(--aura) 55%, transparent), 0 0 6px rgba(0, 0, 0, 0.5) inset;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .select-portrait { width: 100%; height: 100%; object-fit: cover; display: block; image-rendering: pixelated; animation: select-portrait-in 0.3s ease; }
  @keyframes select-portrait-in { from { opacity: 0; transform: scale(1.04); } to { opacity: 1; transform: scale(1); } }

  /* 資訊面板：深色襯底，確保名稱/流派/數值在花背景上清楚可讀 */
  .select-info {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    width: min(90%, 340px); padding: 14px 20px 16px;
    background: rgba(8, 6, 18, 0.78);
    border: 1px solid color-mix(in srgb, var(--aura) 55%, transparent);
    border-radius: 12px;
    box-shadow: 0 0 22px color-mix(in srgb, var(--aura) 28%, transparent), 0 4px 16px rgba(0, 0, 0, 0.45);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .select-name { margin: 0; font-size: clamp(20px, 5vw, 30px); letter-spacing: 4px; color: var(--aura); text-shadow: 0 0 14px color-mix(in srgb, var(--aura) 70%, transparent); }
  .select-school { margin: 0; font-size: 10px; letter-spacing: 3px; color: #d6cdf0; }
  .select-blurb { margin: 2px 0 0; font-size: 9px; line-height: 1.7; color: #b6a9d4; }

  /* 數值條／指示點為執行期 innerHTML 注入，須用 :global 才會套用（Astro scoped 樣式不及於動態節點） */
  .select-stats { display: flex; flex-direction: column; gap: 7px; margin-top: 6px; }
  .select-stats :global(.stat-row) { display: flex; align-items: center; gap: 10px; font-size: 9px; letter-spacing: 1px; color: #d6cdf0; }
  .select-stats :global(.stat-label) { width: 40px; text-align: right; }
  .select-stats :global(.stat-pips) { display: flex; gap: 4px; }
  .select-stats :global(.stat-pip) { width: 16px; height: 9px; border-radius: 2px; background: rgba(214, 205, 240, 0.22); border: 1px solid rgba(214, 205, 240, 0.35); }
  .select-stats :global(.stat-pip.on) { background: var(--aura); border-color: var(--aura); box-shadow: 0 0 8px color-mix(in srgb, var(--aura) 80%, transparent); }

  .select-dots { position: relative; z-index: 2; display: flex; gap: 8px; min-height: 8px; }
  .select-dots :global(.dot) { width: 8px; height: 8px; border-radius: 50%; background: rgba(255, 255, 255, 0.25); cursor: pointer; }
  .select-dots :global(.dot.on) { background: var(--aura); box-shadow: 0 0 8px var(--aura); }

  #select-confirm { position: relative; z-index: 2; background: var(--aura); box-shadow: 0 0 18px color-mix(in srgb, var(--aura) 60%, transparent); }

  @media (max-height: 720px) {
    .witch-select { gap: 10px; }
    .select-blurb { display: none; }
    .select-portrait-wrap { width: min(42vw, 170px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .witch-select, .select-portrait { animation: none; }
    .select-aura { animation: none; }
  }
</style>

<script>
  import { CHARACTERS, type CharacterId } from '@scripts/games/witchrun/engine/characters';

  const byId = (id: string) => document.getElementById(id);
  const canvas = byId('witch-canvas') as HTMLCanvasElement | null;
  const witchEl = document.querySelector('.witch') as HTMLElement | null;
  const titleEl = byId('witch-title');
  const titleStartBtn = byId('witch-start');
  const selectEl = byId('witch-select');
  const portraitEl = byId('select-portrait') as HTMLImageElement | null;
  const nameEl = byId('select-name');
  const schoolEl = byId('select-school');
  const blurbEl = byId('select-blurb');
  const statsEl = byId('select-stats');
  const dotsEl = byId('select-dots');

  const ORDER: CharacterId[] = ['mira', 'gale', 'frost', 'volt'];
  const STORE_KEY = 'witchrun-character';
  let idx = 0;
  let started = false;

  function storedId(): CharacterId {
    const s = localStorage.getItem(STORE_KEY);
    return s && (ORDER as string[]).includes(s) ? (s as CharacterId) : 'mira';
  }

  function pips(label: string, on: number): string {
    const cells = Array.from({ length: 5 }, (_, i) => `<span class="stat-pip${i < on ? ' on' : ''}"></span>`).join('');
    return `<div class="stat-row"><span class="stat-label">${label}</span><span class="stat-pips">${cells}</span></div>`;
  }
  const spdPips = (m: number): number => (m >= 1.15 ? 4 : m <= 0.9 ? 2 : 3);

  function renderSelect(): void {
    const id = ORDER[idx];
    const c = CHARACTERS[id];
    if (portraitEl) {
      portraitEl.src = `/assets/games/witchrun/portrait-${id}.webp`;
      portraitEl.alt = `${c.name} — ${c.school}`;
      portraitEl.style.animation = 'none';
      void portraitEl.offsetWidth;
      portraitEl.style.animation = '';
    }
    if (nameEl) nameEl.textContent = c.name;
    if (schoolEl) schoolEl.textContent = `${c.schoolZh} · ${c.school}`;
    if (blurbEl) blurbEl.textContent = c.blurb;
    selectEl?.style.setProperty('--aura', c.colorCss);
    selectEl?.style.setProperty('--bg', `url(/assets/games/witchrun/portrait-${id}.webp)`);
    if (statsEl) {
      statsEl.innerHTML =
        pips('SPD', spdPips(c.speedMult)) +
        pips('LIFE', Math.min(5, c.startLives)) +
        pips('PWR', c.startPower >= 2 ? 4 : 2);
    }
    if (dotsEl) {
      dotsEl.innerHTML = ORDER.map((_, i) => `<span class="dot${i === idx ? ' on' : ''}" data-i="${i}"></span>`).join('');
    }
  }

  function showSelect(): void {
    if (started) return;
    idx = Math.max(0, ORDER.indexOf(storedId()));
    renderSelect();
    titleEl?.setAttribute('data-exit', '');
    selectEl?.removeAttribute('hidden');
    witchEl?.setAttribute('data-phase', 'select');
  }
  function hideSelect(): void {
    selectEl?.setAttribute('hidden', '');
    titleEl?.removeAttribute('data-exit');
    witchEl?.setAttribute('data-phase', 'title');
  }
  function cycle(d: number): void {
    idx = (idx + d + ORDER.length) % ORDER.length;
    renderSelect();
  }

  async function begin(id: CharacterId): Promise<void> {
    if (started || !canvas) return;
    started = true;
    localStorage.setItem(STORE_KEY, id);
    selectEl?.setAttribute('hidden', '');
    witchEl?.setAttribute('data-phase', 'playing');
    // 標題淡出後移除：與初始化解耦（固定時序，避免 headless 下因載入慢而延後移除）
    if (titleEl) {
      titleEl.setAttribute('data-exit', '');
      setTimeout(() => titleEl.remove(), 480);
    }
    const { startWitchrun } = await import('@scripts/games/witchrun/render/main');
    await startWitchrun(canvas, { character: id }).catch((err: unknown) => console.error('[witchrun] start failed', err));
  }

  titleStartBtn?.addEventListener('click', showSelect);
  byId('select-prev')?.addEventListener('click', () => cycle(-1));
  byId('select-next')?.addEventListener('click', () => cycle(1));
  byId('select-confirm')?.addEventListener('click', () => void begin(ORDER[idx]));
  byId('select-back')?.addEventListener('click', hideSelect);
  dotsEl?.addEventListener('click', (e) => {
    const i = (e.target as HTMLElement)?.dataset?.i;
    if (i != null) { idx = Number(i); renderSelect(); }
  });

  // 觸控左右滑切換角色
  let touchX = 0;
  selectEl?.addEventListener('touchstart', (e) => { touchX = (e as TouchEvent).changedTouches[0].clientX; }, { passive: true });
  selectEl?.addEventListener('touchend', (e) => {
    const dx = (e as TouchEvent).changedTouches[0].clientX - touchX;
    if (Math.abs(dx) > 40) cycle(dx < 0 ? 1 : -1);
  }, { passive: true });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (started) return;
    const selecting = selectEl != null && !selectEl.hasAttribute('hidden');
    if (selecting) {
      if (e.key === 'ArrowLeft') { e.preventDefault(); cycle(-1); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); cycle(1); }
      else if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); void begin(ORDER[idx]); }
      else if (e.key === 'Escape') { e.preventDefault(); hideSelect(); }
    } else if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      showSelect();
    }
  });

  // e2e / 深連結：跳過選角，用儲存或預設角色直接開局
  if (new URLSearchParams(location.search).get('autostart') === '1') void begin(storedId());
</script>
